#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: fd-work <notion-task-url-or-slug>"
  echo ""
  echo "Creates a git worktree + branch for a task and opens a new zellij tab"
  echo "with a worker agent."
  echo ""
  echo "Examples:"
  echo "  fd-work https://www.notion.so/My-Task-abc123def456"
  echo "  fd-work add-store-filtering"
  exit 1
}

[[ $# -lt 1 || "${1:-}" == "--help" || "${1:-}" == "-h" ]] && usage

INPUT="$1"
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || { echo "Error: not in a git repo"; exit 1; }
REPO_NAME=$(basename "$REPO_ROOT")
WORKTREE_BASE="${REPO_ROOT}/../${REPO_NAME}-worktrees"

# Extract slug and Notion URL
if [[ "$INPUT" == *"notion.so"* ]] || [[ "$INPUT" == *"notion.site"* ]]; then
  NOTION_URL="$INPUT"
  # Get the last path segment
  LAST_SEG=$(echo "$INPUT" | sed 's|.*/||' | sed 's|?.*||')
  # If it's just a 32-char hex ID (no title), use short prefix
  if [[ "$LAST_SEG" =~ ^[a-f0-9]{32}$ ]]; then
    SLUG="${LAST_SEG:0:8}"
  else
    # Strip trailing 32-char ID, use the title part
    SLUG=$(echo "$LAST_SEG" | sed 's/-[a-f0-9]\{32\}$//' | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]//g')
  fi
else
  SLUG=$(echo "$INPUT" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | sed 's/[^a-z0-9-]//g')
  NOTION_URL=""
fi

SLUG="${SLUG:0:50}"
BRANCH="task/${SLUG}"
WORKTREE_DIR="${WORKTREE_BASE}/${SLUG}"

launch_kiro() {
  local dir="$1"
  local tab_name="$2"
  sleep 0.5
  # cd explicitly then launch kiro — --cwd alone isn't reliable
  if [[ -n "$NOTION_URL" ]]; then
    zellij action write-chars "cd $dir && kiro-cli chat --agent worker \"Implement task: $NOTION_URL\""
  else
    zellij action write-chars "cd $dir && kiro-cli chat --agent worker"
  fi
  sleep 0.1
  zellij action write 10  # Enter
}

# Check if worktree already exists
if [[ -d "$WORKTREE_DIR" ]]; then
  echo "Worktree already exists at $WORKTREE_DIR"
  zellij action go-to-tab-name "$SLUG" 2>/dev/null || {
    echo "Tab not found. Opening new tab..."
    zellij action new-tab --name "$SLUG"
    launch_kiro "$WORKTREE_DIR" "$SLUG"
  }
  exit 0
fi

# Create worktree
mkdir -p "$WORKTREE_BASE"
echo "Creating branch $BRANCH and worktree at $WORKTREE_DIR..."
git worktree add "$WORKTREE_DIR" -b "$BRANCH" 2>/dev/null || {
  git worktree add "$WORKTREE_DIR" "$BRANCH" 2>/dev/null || {
    echo "Error: could not create worktree. Check if branch '$BRANCH' exists elsewhere."
    exit 1
  }
}

# Open new zellij tab and launch kiro inside it
echo "Opening zellij tab '$SLUG'..."
zellij action new-tab --name "$SLUG"
launch_kiro "$WORKTREE_DIR" "$SLUG"

echo "Worker started in $WORKTREE_DIR (branch: $BRANCH)"
