#!/usr/bin/env bash
# radio — tiny mailbox + zellij wake-up CLI for PM <-> worker handoff.
# See issue #63 for design.
set -euo pipefail

RADIO_HOME="${TASK_FORCE_HOME:-$HOME/.task-force}/radio"
SESSIONS_DIR="$RADIO_HOME/sessions"
MAILBOX_DIR="$RADIO_HOME/mailbox"
LOG_FILE="$RADIO_HOME/log"

usage() {
  cat <<'EOF'
Usage:
  radio send --to ROLE --intent KIND [--pr N] [--issue N] [--repo PATH] [--body TEXT | < body]
  radio check                            list unread messages for this role
  radio read   [--peek|--no-ack] <id>    print body; by default also move inbox/<id>.md -> processed/
  radio ack    <id>                      move message to processed/ (idempotent: no-op if already processed)
  radio register --role ROLE --tab TAB [--repo PATH] --agent claude|kiro [--loadout NAME]
  radio register-alias --role ROLE --alias TARGET [--repo PATH]
                                         point ROLE's address at TARGET's inbox/tab
                                         (task-pm --also; one PM oversees N repos)
  radio ready                            mark this role idle
  radio busy                             mark this role busy
  radio awaiting                         mark this role awaiting user input
  radio stop-hook                        Stop-hook entrypoint: empty inbox -> mark idle; unread
                                         messages -> mark busy + emit block JSON so the agent
                                         continues and drains them (reads hook payload on stdin)
  radio prompt-hook                      UserPromptSubmit-hook entrypoint: mark busy; if the
                                         inbox has unread messages, print a one-line summary
                                         (injected into the model's context by Claude Code)
  radio unregister                       remove this role's session file
  radio orphans                          list session files with stale (>1h) heartbeat
  radio gc [--dry-run] [--max-age-days N]  sweep dead mailboxes + expired processed
                                         messages (default N=14) and rotate the log

Self-identification: every command except `register` reads $TASK_FORCE_ROLE.
Override the mailbox root with $TASK_FORCE_HOME (defaults to ~/.task-force).
EOF
  exit "${1:-1}"
}

# ----- helpers --------------------------------------------------------------

_log() {
  mkdir -p "$RADIO_HOME"
  printf '%s %s\n' "$(_now)" "$*" >>"$LOG_FILE"
}

_now() { date -u +%Y-%m-%dT%H:%M:%SZ; }

_compact_now() { date -u +%Y%m%d-%H%M%S; }

# Parse a UTC ISO-8601 timestamp (YYYY-MM-DDTHH:MM:SSZ, as _now emits) into
# epoch seconds. GNU date wants -d; BSD/macOS date wants -j -f. Prints nothing
# on parse failure so callers can guard with [[ -n ]]. Shared by cmd_orphans
# and cmd_send's dead-session check (#166).
_iso_to_epoch() {
  local ts="$1"
  [[ -n "$ts" ]] || return 0
  date -u -d "$ts" +%s 2>/dev/null \
    || date -u -j -f "%Y-%m-%dT%H:%M:%SZ" "$ts" +%s 2>/dev/null \
    || true
}

_rand_id() {
  # 32 bytes of /dev/urandom is plenty for 6 alphanumeric chars after `tr`
  # filtering — the previous 256-byte read was wasteful, not wrong.
  LC_ALL=C head -c 32 /dev/urandom | LC_ALL=C tr -dc 'a-z0-9' | head -c 6
}

# Portable file mtime / size. GNU `stat` wants `-c`, BSD/macOS `stat` wants `-f`.
# GNU MUST be tried first: on GNU, `-f` means `--file-system` (takes no format
# arg) and `stat -f %m file` *partially succeeds* — it prints filesystem info and
# exits 0, so a BSD-first probe never falls through and returns garbage. `-c` on
# BSD is a clean "illegal option" (exit 1), so GNU-first degrades correctly on
# both. `_file_mtime` prints NOTHING on failure (missing/unreadable file) — a
# destructive-safety contract (#184 review #2): its callers must treat an absent
# mtime as "protect", never as epoch-0/ancient which would sweep a live file on a
# transient stat hiccup. `_file_size` keeps its 0-on-failure default — 0 means
# "small, don't rotate", already the safe direction.
_file_mtime() { stat -c %Y "$1" 2>/dev/null || stat -f %m "$1" 2>/dev/null; }
_file_size()  { stat -c %s "$1" 2>/dev/null || stat -f %z "$1" 2>/dev/null || echo 0; }

# Newest mtime (epoch) of any message under a role's inbox/ + processed/, given
# $now_epoch as the protect-sentinel. When the role has no messages, fall back to
# the mailbox dir's own mtime — so a just-created empty mailbox (recent dir mtime)
# is protected from the gc sweep even if its session file hasn't been written yet,
# while a genuinely aged empty residue dir still ages out. Any unreadable mtime
# collapses the result to $now_epoch (protect — #184 review #2): a stat hiccup on
# a member file must never let the whole dir look ancient. The `[[ -f ]]` guard
# makes this nullglob-independent (unmatched globs stay literal and skip).
_newest_mtime_in() {
  local dir="$1" now_epoch="$2" newest=0 m f
  for f in "$dir"/inbox/* "$dir"/processed/*; do
    [[ -f "$f" ]] || continue
    m=$(_file_mtime "$f") || true
    if [[ -z "$m" ]]; then printf '%s' "$now_epoch"; return 0; fi
    (( m > newest )) && newest=$m
  done
  if (( newest == 0 )); then
    m=$(_file_mtime "$dir") || true
    newest=${m:-$now_epoch}
  fi
  printf '%s' "$newest"
}

# True (0) when $1's mailbox has no unread mail — i.e. inbox/ holds no *.md.
# Gates gc's whole-dir reclaim so a dead role still sitting on undelivered
# messages (the ~64-message legacy `pm` backlog #182 is deferred to adopt) is
# never `rm -rf`'d out from under it; such a role falls through to the
# processed-only sweep, which never touches inbox. Absent inbox dir = empty.
_inbox_empty() {
  local d f
  d=$(_inbox_dir "$1")
  [[ -d "$d" ]] || return 0
  for f in "$d"/*.md; do
    [[ -e "$f" ]] && return 1
  done
  return 0
}

# True (0) when $1's role is "dead" for gc-reclaim purposes, given $now_epoch:
# no session file at all, OR a primary session whose LAST_HEARTBEAT is >1h stale
# — the same threshold `radio orphans` and cmd_send's dead-session guard use, and
# the effectively-idle notion #127 is chartered to self-heal. Reclaiming a
# crashed worker's lingering-.info mailbox is the single biggest accumulation
# source gc exists to fix; keying only on file *existence* would deem it immortal.
# Alias sessions (#165) carry no heartbeat of their own (their liveness tracks the
# primary), so they are never judged dead here. A missing/unparseable heartbeat is
# treated as alive (conservative — never infer death from a parse failure). Always
# paired with `_inbox_empty` before any whole-dir removal, so a dead-by-heartbeat
# role still holding unread mail keeps its inbox.
_session_dead() {
  local role="$1" now_epoch="$2" sf hb hb_epoch
  sf=$(_session_file "$role")
  [[ -f "$sf" ]] || return 0
  [[ -n "$(_session_field "$sf" ALIAS || true)" ]] && return 1
  hb=$(_session_field "$sf" LAST_HEARTBEAT || true)
  hb_epoch=$(_iso_to_epoch "$hb")
  [[ -n "$hb_epoch" ]] || return 1
  (( now_epoch - hb_epoch > 3600 ))
}

# Truncate $LOG_FILE to its last ~512KB once it grows past ~1MB (#169). `tail
# -c` may clip a partial first line — acceptable for an append-only debug log.
# No-op when the file is small or absent. Known race (#184 review #5): a
# concurrent `_log` `>>` append landing between the `tail` read and the `mv` is
# lost. It's a best-effort debug log, not mail, and rotation only fires on the
# rare >1MB crossing (now gated behind the once-hourly register throttle), so the
# window is negligible; we accept it rather than add locking on the hot path.
_rotate_log() {
  [[ -f "$LOG_FILE" ]] || return 0
  local size max keep
  size=$(_file_size "$LOG_FILE")
  max=$(( 1024 * 1024 )); keep=$(( 512 * 1024 ))
  if (( size > max )); then
    tail -c "$keep" "$LOG_FILE" > "$LOG_FILE.tmp" 2>/dev/null \
      && mv "$LOG_FILE.tmp" "$LOG_FILE"
    _log "gc: rotated log (was $size bytes, kept last $keep)"
  fi
}

_require_role() {
  if [[ -z "${TASK_FORCE_ROLE:-}" ]]; then
    echo "Error: \$TASK_FORCE_ROLE is not set (task-work / task-pm should set it)" >&2
    exit 2
  fi
  _validate_role "$TASK_FORCE_ROLE" || exit 2
}

# Silent no-op for hook-invoked commands when $TASK_FORCE_ROLE is unset (#93):
# plain `claude` in a task-force-equipped repo fires SessionStart/UserPromptSubmit/Stop
# hooks with no role, and the hooks have nothing to mutate. Exiting non-zero
# here would block UserPromptSubmit; exit 0 silently instead.
_silent_exit_if_no_role() {
  [[ -z "${TASK_FORCE_ROLE:-}" ]] && exit 0
  return 0
}

# Role gate for hook entrypoints, extending the #93 no-role gate to invalid
# roles (#164 review). Hook-invoked commands must never exit nonzero — on
# UserPromptSubmit a nonzero exit blocks AND erases the user's typed prompt —
# but a set-yet-invalid $TASK_FORCE_ROLE (e.g. a repo whose basename contains
# a dot) used to hit _require_role's `exit 2` inside _update_state, blocking
# every prompt for the session's life. Unset role → silent 0 (plain `claude`
# session); invalid role → logged 0 (misconfiguration, but never the user's
# problem mid-prompt). User-invoked commands (read, ack, send) keep failing
# loudly via _require_role.
_hook_role_gate() {
  [[ -z "${TASK_FORCE_ROLE:-}" ]] && exit 0
  if ! _validate_role "$TASK_FORCE_ROLE" 2>/dev/null; then
    _log "hook: invalid role '$TASK_FORCE_ROLE' — no-op"
    # A human typing `radio busy` at a shell shouldn't have their toggle
    # silently ignored — note it on stderr (still exit 0). Hook invocations
    # pipe stdin, so they stay silent.
    if [[ -t 0 ]]; then
      echo "radio: invalid role '$TASK_FORCE_ROLE' — ignoring (hook no-op)" >&2
    fi
    exit 0
  fi
  return 0
}

# Shared stdin-JSON parse for hook entrypoints (#164 notes — previously
# duplicated between cmd_stop_hook and cmd_unregister; #168 needs it too).
# _read_hook_payload slurps the payload Claude Code pipes on stdin into
# $HOOK_PAYLOAD (terminal stdin → empty: manual invocations carry none);
# _hook_payload_field extracts one top-level field, "" on absent field,
# malformed JSON, or jq-less host. Neither ever returns nonzero.
HOOK_PAYLOAD=""
_read_hook_payload() {
  HOOK_PAYLOAD=""
  if [[ ! -t 0 ]]; then
    HOOK_PAYLOAD=$(cat 2>/dev/null || true)
  fi
}

_hook_payload_field() {
  local key="$1"
  [[ -n "$HOOK_PAYLOAD" ]] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  printf '%s' "$HOOK_PAYLOAD" | jq -r --arg k "$key" '.[$k] // empty' 2>/dev/null || true
}

# Atomic write: stage into <file>.tmp.<rand> then rename. mv on POSIX is atomic
# within the same directory, so readers never see a half-written session file.
_atomic_write() {
  local target="$1" tmp
  tmp="${target}.tmp.$$.$RANDOM"
  mkdir -p "$(dirname "$target")"
  cat >"$tmp"
  mv -f "$tmp" "$target"
}

# Read a single KEY=VALUE field from a session file. Never `source` the file
# (it's untrusted input from another process); grep+cut is enough.
_session_field() {
  local file="$1" key="$2"
  [[ -f "$file" ]] || return 1
  local line
  line=$(grep -E "^${key}=" "$file" | head -1) || return 1
  printf '%s' "${line#*=}"
}

# Reject role names that could let a caller escape $SESSIONS_DIR / $MAILBOX_DIR
# via `..` or `/`. Today roles come from task-work / task-pm (`worker-<basename>-<slug>`
# and `pm`), so the values are already safe — but `_session_file` / `_inbox_dir`
# build paths by string concatenation, so we validate at the boundary
# (`_require_role` for self-identifying commands; `cmd_send` for `--to`) before
# any path is constructed.
_validate_role() {
  local role="$1"
  case "$role" in
    # Leading `-` is rejected (#169): a role starting with a dash gets swallowed
    # as a flag by every `radio <cmd> --role/--to "$role"` call site, which is how
    # the historical `--tab` mailbox got created (a malformed register, pre-#93
    # guard). No legitimate role (`pm`, `pm-<repo>`, `worker-<repo>-<slug>`) starts
    # with a dash, so this is a pure footgun-killer.
    ""|-*|*..*|*/*) echo "radio: invalid role: $role" >&2; return 1 ;;
    *[!a-zA-Z0-9_-]*) echo "radio: invalid role: $role" >&2; return 1 ;;
  esac
}

# Sanitize a string to radio's role-segment charset (#165 RC-6). Byte-identical
# with lib/repo-name.sh::aw_sanitize_repo_name and task-work's sanitize_slug so a
# repo name derived launcher-side matches one re-derived here at register time.
_sanitize_role_segment() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | sed 's/[^a-z0-9-]//g'
}

# Canonical MAIN worktree root for the git repo containing $1 (#165 RC-2/RC-7).
# basename(worktree) is the slug and worktree paths differ across checkouts of
# one repo — so we resolve --git-common-dir's parent, which is the same absolute
# path for every worktree of a repo. Empty when git can't answer.
_repo_root_of() {
  local dir="$1" common
  [[ -n "$dir" ]] || return 0
  common=$(git -C "$dir" rev-parse --git-common-dir 2>/dev/null) || return 0
  [[ -n "$common" ]] || return 0
  case "$common" in /*) : ;; *) common="$dir/$common" ;; esac
  (cd "$common/.." 2>/dev/null && pwd) || return 0
}

# Worktree-proof main-repo name (sanitized to the role charset) for $1 (#165
# RC-2). Empty when git can't answer (the caller then falls back to whatever it
# has). See lib/repo-name.sh for the rationale.
_repo_name_of() {
  local root
  root=$(_repo_root_of "$1") || return 0
  [[ -n "$root" ]] || return 0
  _sanitize_role_segment "$(basename "$root")"
}

# Strip the idle/busy emoji prefix that `_rename_tab` paints onto TAB= so we
# can compare against $ZELLIJ_TAB (the bare slug set by task-work / task-pm at
# pane creation time) and surface the underlying name for callers that need it.
_strip_tab_prefix() {
  local s="$1"
  s="${s#⏸️ }"
  s="${s#▶️ }"
  s="${s#❓︎ }"
  printf '%s' "$s"
}

# Resolve a zellij tab's stable id from its visible name. Empty stdout means
# "lookup failed" (zellij not reachable, jq absent, name not found) — callers
# must treat that as a hard skip so we never operate on the wrong tab (#102).
#
# Emoji-prefix awareness (#140): _rename_tab paints the visible tab name to
# "⏸️ <slug>" / "▶️ <slug>" / "❓︎ <slug>" reflecting STATE. Callers always
# query by the bare slug ($ZELLIJ_TAB / cmd_register's --tab arg) — that's
# the stable identifier captured at pane creation and never mutates. So a
# literal name match against the painted name misses on every flip past
# idle. We compare against both the bare name AND any of the three emoji-
# prefixed variants so the lookup survives _rename_tab's repaints. This is
# the symmetric fix for #117 (cmd_register) AND the same loss in
# _ensure_session_file's re-seed path (Bug B in #140).
_zellij_tab_id_by_name() {
  local target="$1"
  [[ -n "$target" ]] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  zellij action list-tabs --json 2>/dev/null \
    | jq -r --arg n "$target" '
        [.[] | select(
          .name == $n
          or .name == ("⏸️ " + $n)
          or .name == ("▶️ " + $n)
          or .name == ("❓︎ " + $n)
        ) | .tab_id] | .[0] // empty
      ' 2>/dev/null
}

# Pick a writable pane on the given tab. Prefer the tab's own focused pane
# (where the user's keyboard sits when they switch over); fall back to any
# non-plugin pane on that tab. Empty stdout means "no usable pane" — caller
# must skip rather than write to the focused tab's pane by accident (#102).
_zellij_pane_in_tab() {
  local target="$1"
  case "$target" in *[!0-9]*|"") return 0 ;; esac
  command -v jq >/dev/null 2>&1 || return 0
  zellij action list-panes --json --tab 2>/dev/null \
    | jq -r --argjson t "$target" '
        [.[] | select(.tab_id == $t and (.is_plugin // false) == false)]
        | (map(select(.is_focused == true))[0] // .[0]) | .id // empty
      ' 2>/dev/null
}

# Resolve the visible name of the zellij tab that currently holds a given
# tab_id. Empty stdout means "no tab with that id" (id gone after a restart, or
# zellij/jq unreachable). This is the read half of the #167 identity check: a
# TAB_ID is only trustworthy if the tab still AT that id still bears the name we
# recorded — a recycled id after a restart bears a different tab's name, or none.
_zellij_tab_name_by_id() {
  local target="$1"
  case "$target" in *[!0-9]*|"") return 0 ;; esac
  command -v jq >/dev/null 2>&1 || return 0
  zellij action list-tabs --json 2>/dev/null \
    | jq -r --argjson t "$target" \
        '[.[] | select(.tab_id == $t) | .name] | .[0] // empty' 2>/dev/null
}

# True (exit 0) when a zellij session of this exact name is currently live (not
# EXITED) in this host's zellij server list (#167 review #2). Used to detect the
# *concurrent-session* case: if a recipient's recorded ZELLIJ_SESSION names a
# different but still-running server, its real tab lives somewhere we cannot
# write to — so we must NOT deliver into this server's same-named look-alike tab
# nor repair the live owner's file. `zellij list-sessions --no-formatting`
# prints "<name> [Created …] (…)" one per line; $1 is the session name and the
# "(EXITED …)" marker rules out a resurrectable-but-dead session. On any failure
# (flag unsupported, zellij down) this returns non-zero → "not alive" → callers
# fall through to the name-at-id verification, which still blocks same-server
# misdelivery; only the rarer cross-server concurrent case degrades.
_zellij_session_alive() {
  local name="$1"
  [[ -n "$name" ]] || return 1
  [[ -n "${ZELLIJ:-}" ]] || return 1
  command -v zellij >/dev/null 2>&1 || return 1
  zellij list-sessions --no-formatting 2>/dev/null \
    | awk -v n="$name" '!/EXITED/ && $1 == n { f = 1 } END { exit(f ? 0 : 1) }'
}

# The load-bearing #167 check, shared by cmd_send and _rename_tab. Given a
# session file and the role's bare tab slug, return the tab_id it is safe to
# drive a zellij action against — verifying identity rather than trusting the
# environment, because a session *name* is not a server-instance token
# (`zellij attach -c main` after a reboot yields recorded == live with every id
# stale). Protocol via exit code + stdout:
#   rc 0 + id  : recorded TAB_ID verified (the tab still at that id still bears
#                the recorded bare name) — use as-is, no repair.
#   rc 3 + id  : recorded id was stale/gone; recovered a fresh id by name —
#                use it AND repair the file so the next op is id-driven again.
#   rc 1 + ""  : unresolvable (owner alive in another server, or the tab is
#                gone and no name match) — caller queues (send) / skips (rename).
_live_tab_id() {
  local f="$1" bare="$2"
  local rec_id rec_session curr_session
  rec_id=$(_session_field "$f" TAB_ID || true)
  rec_session=$(_session_field "$f" ZELLIJ_SESSION || true)
  curr_session="${ZELLIJ_SESSION_NAME:-}"

  # Concurrency guard (#167 review #2): the recorded owner is a *different*,
  # still-running server → its tab is unreachable from here and its file must
  # not be repaired to point at our look-alike. Queue instead of misdelivering.
  if [[ -n "$rec_session" && "$rec_session" != "$curr_session" ]] \
       && _zellij_session_alive "$rec_session"; then
    return 1
  fi

  # Verify the recorded id against reality: the tab still at that id must still
  # bear the recorded bare name (emoji prefix stripped from both). Restart-proof,
  # rename-proof, and collision-proof (we check the name AT the id, so a
  # first-match impostor at a different id can't slip through). #167 review #1.
  if [[ -n "$rec_id" ]]; then
    local name_at_id
    name_at_id=$(_zellij_tab_name_by_id "$rec_id")
    if [[ -n "$name_at_id" && "$(_strip_tab_prefix "$name_at_id")" == "$bare" ]]; then
      printf '%s' "$rec_id"
      return 0
    fi
  fi

  # Stale or gone: re-resolve the role's tab by its bare name. A hit is a fresh
  # id the caller repairs into the file (rc 3); a miss is unresolvable (rc 1).
  local recovered
  recovered=$(_zellij_tab_id_by_name "$bare" || true)
  if [[ -n "$recovered" ]]; then
    printf '%s' "$recovered"
    return 3
  fi
  return 1
}

# Replace-or-append one or more KEY=VALUE fields in a session file, in place and
# TOCTOU-safe. Snapshots the file first so a concurrent unregister (the #140/#151
# cascade) that unlinks it mid-call is a no-op rather than resurrecting a stale
# or empty file (#164 crash class). This is the single home for the awk
# replace-or-append grammar that _update_state, _rename_tab's TAB= repaint, and
# the #167 tab-binding repair had each grown a copy of (#167 review #5).
_session_set_fields() {
  local f="$1"; shift
  local content
  content=$(cat "$f" 2>/dev/null || true)
  [[ -n "$content" ]] || return 0
  # Pass the KEY=VAL pairs through the environment, not `-v`: BSD/macOS awk
  # rejects a literal newline in a `-v` value ("newline in string"), and values
  # like the emoji-painted TAB= are safest untouched by -v backslash handling.
  # ENVIRON[] is POSIX and newline-clean.
  local pairs="" kv
  for kv in "$@"; do
    pairs+="${kv}"$'\n'
  done
  printf '%s\n' "$content" | RADIO_SET_PAIRS="$pairs" awk '
    BEGIN {
      n = split(ENVIRON["RADIO_SET_PAIRS"], arr, "\n")
      for (i = 1; i <= n; i++) {
        if (arr[i] == "") continue
        eq = index(arr[i], "=")
        want[substr(arr[i], 1, eq - 1)] = substr(arr[i], eq + 1)
      }
    }
    {
      eq = index($0, "=")
      k = (eq > 0) ? substr($0, 1, eq - 1) : ""
      if (k != "" && (k in want)) { print k "=" want[k]; done[k] = 1; next }
      print
    }
    END { for (k in want) if (!(k in done)) print k "=" want[k] }
  ' | _atomic_write "$f"
}

# Restamp a session file's tab binding after a #167 name recovery: the fresh
# TAB_ID plus the current ZELLIJ_SESSION so the next op is id-driven again. Skip
# the session restamp when the live name is empty (ZELLIJ_SESSION= is advisory
# and must not self-destruct into the unguarded class — #167 review #8).
_repair_tab_binding() {
  local f="$1" id="$2" curr="${ZELLIJ_SESSION_NAME:-}"
  if [[ -n "$curr" ]]; then
    _session_set_fields "$f" "TAB_ID=$id" "ZELLIJ_SESSION=$curr"
  else
    _session_set_fields "$f" "TAB_ID=$id"
  fi
}

_session_file() {
  printf '%s/%s.info' "$SESSIONS_DIR" "$1"
}

# Sidecar for the per-role loadout name (#140). cmd_register writes it from
# its --loadout CLI arg; _ensure_session_file reads from it during a re-seed.
# Separate from the main session file so it survives cmd_unregister's `rm -f`
# of <role>.info — by definition, we re-seed because the .info file was just
# wiped, so we can't read the previous LOADOUT= line out of it. The bare env
# var ($TASK_FORCE_LOADOUT) isn't available either: hook subshells inherit
# Claude Code's env, not task-work's launch-time exports — that fallback to
# the literal string "unknown" was Bug C in #140.
_loadout_sidecar() {
  printf '%s/%s.loadout' "$SESSIONS_DIR" "$1"
}

# Agent sidecar (#151). Same problem as LOADOUT: $TASK_FORCE_AGENT isn't
# exported into Claude Code's hook subshells, so _ensure_session_file's
# previous fallback to "${TASK_FORCE_AGENT:-claude}" silently wrote
# AGENT=claude for kiro-* workers on every re-seed. Parallel sidecar, parallel
# write/read/sweep semantics — no current runtime consumer, but a kiro worker
# whose re-seeded session reports AGENT=claude is a footgun if anyone wires
# AGENT-conditional behaviour later.
_agent_sidecar() {
  printf '%s/%s.agent' "$SESSIONS_DIR" "$1"
}

# Alias-list sidecar for a primary PM (#165 RC-4a). `task-pm --also` records
# each alias here (one `pm-<other>|<repo>` per line) so cmd_register can re-seed
# the alias session files on every SessionStart — self-heal parity with the
# loadout/agent sidecars, so a /compact, restart, or an erroneous unregister
# sweep (the #140 cascade) doesn't silently drop multi-repo routing mid-session.
_aliases_sidecar() {
  printf '%s/%s.aliases' "$SESSIONS_DIR" "$1"
}

_inbox_dir()    { printf '%s/%s/inbox'     "$MAILBOX_DIR" "$1"; }
_processed_dir(){ printf '%s/%s/processed' "$MAILBOX_DIR" "$1"; }

# Self-healing: write a session file for $TASK_FORCE_ROLE if one is missing,
# using the identity env vars task-work / task-pm injected at tab launch
# (#107 follow-up). The session file is treated as a soft cache, not a lock —
# Claude Code's SessionEnd hook fires on intra-session events (`/clear`,
# `/compact`, resume) as well as real exit, so a spurious unregister mid-life
# would otherwise brick all subsequent busy/ready/send operations for the
# role. Returns 1 (without writing anything) if there's no identity env to
# rebuild from, so non-task-force `claude` sessions stay no-ops.
_ensure_session_file() {
  _require_role
  local f
  f=$(_session_file "$TASK_FORCE_ROLE")
  [[ -f "$f" ]] && return 0

  [[ -n "${ZELLIJ_TAB:-}" ]] || { _log "ensure_session: \$ZELLIJ_TAB unset; cannot re-seed $TASK_FORCE_ROLE"; return 1; }

  local tab_id=""
  if [[ -n "${ZELLIJ:-}" ]] && command -v zellij >/dev/null 2>&1; then
    tab_id=$(_zellij_tab_id_by_name "$ZELLIJ_TAB" || true)
  fi

  # Bind the re-seeded TAB_ID to this zellij server instance (#167) so a later
  # send/rename can detect a TAB_ID that outlived its server. Same value the
  # real register captures; empty outside zellij.
  local zsession="${ZELLIJ_SESSION_NAME:-}"

  # LOADOUT recovery (#140 Bug C): the hook subshell doesn't inherit
  # $TASK_FORCE_LOADOUT, so the previous fallback to "${TASK_FORCE_LOADOUT:-unknown}"
  # wrote the literal string "unknown" on every re-seed. Read from the
  # sidecar that cmd_register persisted at register time. Fall back to the
  # env var only as a last resort (covers test harnesses that exercise
  # _ensure_session_file without going through register first).
  local loadout=""
  local sidecar
  sidecar=$(_loadout_sidecar "$TASK_FORCE_ROLE")
  # TOCTOU-safe read (#150 review): the sidecar can be unlinked by a
  # concurrent cmd_unregister between any pre-check and the read — the
  # unregister cascade documented in #140 is exactly that race window.
  # `cat … 2>/dev/null || true` collapses three failure modes into "empty
  # string" without tripping set -e: file absent, file unlinked mid-read,
  # file unreadable. The env-var fallback below handles the empty case.
  #
  # Why not the obvious `loadout=$(<"$sidecar" || true)` the reviewer
  # suggested: bash's `<file` is a command-substitution-only shorthand, not
  # a real command, and `<file || true` short-circuits such that the read
  # never returns the file's contents — so the sidecar value would be lost
  # even on the happy path. Verified with `bash -c 'echo x>/tmp/f; v=$(</tmp/f || true); echo "[$v]"'`
  # printing `[]`. cat is the unambiguous form.
  loadout=$(cat "$sidecar" 2>/dev/null || true)
  [[ -n "$loadout" ]] || loadout="${TASK_FORCE_LOADOUT:-unknown}"

  # AGENT recovery (#151): same hook-subshell unset story as LOADOUT — the
  # cascade wipes .info, and the next re-seed used to default to "claude"
  # regardless of whether this was a kiro-* worker. Read the agent sidecar
  # cmd_register persisted; fall back to the env var only for test paths that
  # exercise _ensure_session_file directly. Same TOCTOU-safe `cat … || true`
  # pattern as the loadout read above for the same reason (concurrent
  # unregister race window).
  local agent=""
  local agent_sidecar
  agent_sidecar=$(_agent_sidecar "$TASK_FORCE_ROLE")
  agent=$(cat "$agent_sidecar" 2>/dev/null || true)
  [[ -n "$agent" ]] || agent="${TASK_FORCE_AGENT:-claude}"

  local repo repo_name=""
  repo=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
  # Persist REPO_NAME= on re-seed too (#165 RC-2), worktree-proof, so the shim's
  # sender-derivation keeps working after a self-heal wiped the original .info.
  if [[ -n "$repo" ]]; then
    repo_name=$(_repo_name_of "$repo")
    [[ -n "$repo_name" ]] || repo_name=$(_sanitize_role_segment "$(basename "$repo")")
  fi

  {
    printf 'ROLE=%s\nTAB=%s\nTAB_ID=%s\nZELLIJ_SESSION=%s\nREPO=%s\nREPO_NAME=%s\nSTATE=idle\nLAST_HEARTBEAT=%s\nAGENT=%s\nLOADOUT=%s\n' \
      "$TASK_FORCE_ROLE" "$ZELLIJ_TAB" "$tab_id" "$zsession" "$repo" "$repo_name" "$(_now)" \
      "$agent" "$loadout"
    # Preserve the --auto opt-in across self-heal so cmd_send keeps using CR
    # for wake-up after an intra-session re-seed (#128). Use `if` rather than
    # `&&` so the brace group exits 0 when the flag is absent — otherwise
    # pipefail would surface a stray exit-1 through `| _atomic_write` and
    # `set -e` would abort the re-seed.
    if [[ "${TASK_FORCE_AUTO_SUBMIT:-}" == "1" ]]; then
      printf 'AUTO_SUBMIT=1\n'
    fi
  } | _atomic_write "$f"

  mkdir -p "$(_inbox_dir "$TASK_FORCE_ROLE")" "$(_processed_dir "$TASK_FORCE_ROLE")"
  _log "ensure_session: re-seeded $TASK_FORCE_ROLE (file was missing) tab_id=$tab_id loadout=$loadout agent=$agent"
}

# Update STATE=… and LAST_HEARTBEAT=… on the current session file.
_update_state() {
  local new_state="$1"
  _require_role
  _ensure_session_file || { _log "update_state: no identity env for $TASK_FORCE_ROLE"; return 0; }
  local f
  f=$(_session_file "$TASK_FORCE_ROLE")

  # TOCTOU guard (#164 review): the unregister cascade (#140/#151) can unlink
  # the session file between _ensure_session_file's check and this rewrite.
  # awk reading the path directly would exit 2 — fatal under set -e, so the
  # hook exits nonzero (on UserPromptSubmit that blocks and erases the user's
  # typed prompt; observed live as `awk: can't open file <role>.info`) —
  # while _atomic_write on the pipe's right side would still fire and
  # resurrect an *empty* session file. Snapshot the content first: a
  # vanished/empty file is "nothing to update", same as the
  # _ensure_session_file failure path above.
  local content
  content=$(cat "$f" 2>/dev/null || true)
  [[ -n "$content" ]] || { _log "update_state: session file vanished for $TASK_FORCE_ROLE — skipping"; return 0; }

  # Replace STATE/LAST_HEARTBEAT, preserve everything else (shared grammar #167 review #5).
  _session_set_fields "$f" "STATE=$new_state" "LAST_HEARTBEAT=$(_now)"

  _rename_tab "$new_state"
}

# Prefix the role's recorded zellij tab with an emoji reflecting STATE. No-op
# silently if zellij isn't running, $ZELLIJ is unset, we have no TAB= in the
# session file, or the calling pane is on a different tab than the role's tab
# (defense in depth — see the $ZELLIJ_TAB safeguard below). On success, also
# rewrite TAB= in the session file so subsequent lookups match the visible
# tab name (#95, #102).
_rename_tab() {
  local new_state="$1"
  [[ -n "${ZELLIJ:-}" ]] || return 0
  command -v zellij >/dev/null 2>&1 || return 0
  [[ -n "${TASK_FORCE_ROLE:-}" ]] || return 0

  local f current bare prefix new_name
  f=$(_session_file "$TASK_FORCE_ROLE")
  [[ -f "$f" ]] || return 0

  current=$(_session_field "$f" TAB || true)
  [[ -n "$current" ]] || return 0

  # Strip any existing emoji prefix so repeated calls don't stack them (e.g.
  # the previous run persisted `⏸️ pm` into TAB=; without stripping we'd
  # rename to `⏸️ ⏸️ pm`).
  bare=$(_strip_tab_prefix "$current")

  # Defense-in-depth safeguard (#102): if the caller's pane lives on a tab
  # other than the role's tab, refuse to rename. $ZELLIJ_TAB is set by
  # task-work / task-pm to the bare slug at pane creation and never mutates,
  # so it stays a stable comparison point even after we paint emoji prefixes
  # onto the visible name. This catches `TASK_FORCE_ROLE=other radio ready`
  # invoked from the wrong pane even if the per-tab API call below were to
  # regress to a focused-tab call.
  if [[ -n "${ZELLIJ_TAB:-}" && "$ZELLIJ_TAB" != "$bare" ]]; then
    _log "_rename_tab: \$ZELLIJ_TAB=$ZELLIJ_TAB != role tab=$bare — skipping"
    return 0
  fi

  case "$new_state" in
    idle) prefix="⏸️ " ;;
    busy) prefix="▶️ " ;;
    awaiting) prefix="❓︎ " ;;
    *)    return 0 ;;
  esac
  new_name="${prefix}${bare}"

  # Resolve the tab_id to rename via the shared #167 identity check: trust the
  # recorded TAB_ID only when the tab still at that id still bears this role's
  # bare name, else recover by name (and repair). rc 1 → the tab is gone /
  # owned by a live sibling server → skip rather than rename an unrelated tab.
  # `rc=0; …|| rc=$?` rather than `…; rc=$?` because `set -e` treats a command
  # substitution assignment whose command exits non-zero (rc 1/3 here) as a
  # failed simple command and aborts before the next line runs.
  local tab_id rc=0
  tab_id=$(_live_tab_id "$f" "$bare") || rc=$?
  if [[ "$rc" -eq 1 || -z "$tab_id" ]]; then
    _log "_rename_tab: no live tab_id for role $TASK_FORCE_ROLE — skipping"
    return 0
  fi

  zellij action rename-tab-by-id "$tab_id" "$new_name" >/dev/null 2>&1 || return 0

  # Recovered a fresh id by name (recorded id was stale/gone) — restamp the
  # binding so the next op is id-driven again (#167).
  [[ "$rc" -eq 3 ]] && _repair_tab_binding "$f" "$tab_id"

  # Repaint TAB= so a human inspecting the session file sees the current name.
  # Purely cosmetic — the id is the address. TOCTOU-safe via the shared setter.
  _session_set_fields "$f" "TAB=$new_name"
}

# Legacy `pm` inbox adoption (#182). Post-#165 no role ever registers as the
# literal `pm` again, so `mailbox/pm/inbox` is write-only: the pre-migration
# backlog (the July "no session for pm" strandings) plus any env-less step-4
# `--to pm` fallback sends land there with no consumer. When a repo-scoped
# pm-<reponame> role registers FRESH (the #168 offline→online gate) and that
# legacy inbox is non-empty with no live literal-`pm` session, migrate each
# message into THIS role's inbox, stamping an `adopted-from:` provenance line
# into the frontmatter so the reading agent (and any postmortem) sees where it
# came from. The caller's existing drain-on-register summary (#168) then
# surfaces them alongside this role's own backlog — no separate print path.
#
# One-time backfill by construction: once moved, each message acks normally via
# `radio read <id>`, and the legacy inbox goes empty, closing the write-only
# fallback path for good. Coordinated with gc (#169): gc's whole-dir reclaim is
# gated behind `_inbox_empty`, so it can never race us — it only becomes able to
# reap the dead `pm` mailbox AFTER this adoption has emptied it. Sets
# ADOPTED_LEGACY_N to the number migrated (0 when nothing to do). Never returns
# nonzero — a migration hiccup must not abort register.
ADOPTED_LEGACY_N=0
_adopt_legacy_pm_inbox() {
  ADOPTED_LEGACY_N=0
  local role="$1" now_epoch="$2"
  # Only repo-scoped PMs adopt. The literal `pm` never registers post-#165, but
  # guard anyway so a hand-run `register --role pm` can't adopt its own inbox.
  [[ "$role" == pm-* ]] || return 0
  # A live literal-`pm` session (heartbeat fresh) still owns its inbox — don't
  # steal from it. _session_dead is true (0) when there is no `pm` session file
  # at all (the normal post-#165 state) or its heartbeat is >1h stale.
  _session_dead pm "$now_epoch" || return 0

  local src
  src=$(_inbox_dir pm)
  [[ -d "$src" ]] || return 0

  shopt -s nullglob
  local legacy=("$src"/*.md)
  shopt -u nullglob
  (( ${#legacy[@]} > 0 )) || return 0

  local dst
  dst=$(_inbox_dir "$role")
  mkdir -p "$dst"

  local f base target tmp n=0 stamp
  stamp=$(_now)
  for f in "${legacy[@]}"; do
    base="${f##*/}"
    target="$dst/$base"
    # Filename collision (the timestamp+rand ids make this near-impossible) —
    # skip rather than clobber a genuine message already in this inbox.
    if [[ -e "$target" ]]; then
      _log "adopt: skip collision $base role=$role"
      continue
    fi
    # Inject the provenance line right after the opening `---` fence, preserving
    # the rest verbatim. It stays inside the frontmatter (fence==1) so
    # _inbox_summary's parser still reads from/intent/pr/issue, and `adopted-from:`
    # matches none of its anchored field patterns, so the summary line is
    # unchanged. Stage to a sibling temp then rename (atomic within the dir) so a
    # crash mid-write never leaves a half-file in the inbox, and only unlink the
    # source once the target is safely in place.
    tmp="$dst/.adopt.$$.$RANDOM"
    if awk -v r="$role" -v ts="$stamp" '
        NR==1 && $0=="---" { print; print "adopted-from: pm (legacy inbox, backfilled by " r " at " ts ")"; next }
        { print }
      ' "$f" > "$tmp" 2>/dev/null; then
      mv -f "$tmp" "$target"
      rm -f "$f"
      n=$(( n + 1 ))
    else
      rm -f "$tmp" 2>/dev/null || true
      _log "adopt: failed to migrate $base role=$role"
    fi
  done

  ADOPTED_LEGACY_N=$n
  (( n > 0 )) && _log "adopt: migrated $n legacy pm message(s) into role=$role"
  return 0
}

# ----- subcommands ----------------------------------------------------------

cmd_register() {
  local role="" tab="" repo="" agent="" loadout=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --role)    role="$2";    shift 2 ;;
      --tab)     tab="$2";     shift 2 ;;
      --repo)    repo="$2";    shift 2 ;;
      --agent)   agent="$2";   shift 2 ;;
      --loadout) loadout="$2"; shift 2 ;;
      *) echo "register: unknown flag $1" >&2; exit 2 ;;
    esac
  done
  [[ -n "$role"  ]] || { echo "register: --role required"  >&2; exit 2; }
  [[ -n "$agent" ]] || { echo "register: --agent required" >&2; exit 2; }
  _validate_role "$role" || exit 2

  # Resolve the zellij stable tab_id once, here at register time, and persist
  # it as TAB_ID= alongside TAB=. From this point on, _rename_tab / cmd_send
  # drive their zellij actions by id, not by name — so subsequent renames
  # (idle ↔ busy emoji flips) and even user-initiated renames don't break
  # lookups, and a name collision between two tabs can't misroute a wake-up
  # to the wrong tab (#102 review feedback). On lookup failure (zellij not
  # running, jq absent, --tab name not found) we leave TAB_ID= empty and log
  # it — non-zellij / CI paths keep working, and _rename_tab can still fall
  # back to a name lookup the next time it runs.
  # Bind the captured TAB_ID to this zellij server instance (#167). tab ids are
  # only unique within one server lifetime; persisting the session name lets a
  # later send/rename detect a TAB_ID that outlived a restart via the identity
  # check in _live_tab_id. Empty outside zellij / when unresolved.
  local tab_id="" zsession="${ZELLIJ_SESSION_NAME:-}"
  if [[ -n "${ZELLIJ:-}" ]] && command -v zellij >/dev/null 2>&1; then
    tab_id=$(_zellij_tab_id_by_name "$tab" || true)
  fi

  # Worktree-proof repo name (#165 RC-2): derive the MAIN repo name from --repo
  # (a linked worktree's path) via git-common-dir, so the shim reads a persisted
  # REPO_NAME= instead of basename(REPO=) — which is the worktree slug. Fall back
  # to the sanitized basename when --repo isn't a git repo (test / CI paths).
  local repo_name=""
  if [[ -n "$repo" ]]; then
    repo_name=$(_repo_name_of "$repo")
    [[ -n "$repo_name" ]] || repo_name=$(_sanitize_role_segment "$(basename "$repo")")
  fi

  local f
  f=$(_session_file "$role")

  # Snapshot whether a session file already exists BEFORE we write one below —
  # this is the offline→online gate for drain-on-register (#168, #174 review
  # Finding 1). SessionStart re-fires on /compact, /clear, and resume, so
  # cmd_register runs many times per session; only the FIRST (no session file
  # yet) is a genuine offline→online transition where "queued while offline" is
  # true. On re-register, messages in the inbox arrived while the role was
  # *online* — printing "queued while this role was offline" would be false,
  # and re-injected on every compaction. So we drain only when fresh=1. The
  # /clear case (context wiped, re-surfacing genuinely useful) is safely
  # backstopped by prompt-hook on the next user prompt.
  # An ALIAS-only placeholder (task-pm --also) is not a real prior registration:
  # treat it as absent for both the fresh gate (so a real PM claiming its own
  # address still drains its backlog, #168 / RC-4c) and the collision check (an
  # alias's REPO= is bookkeeping, not a rival PM). We overwrite it below.
  local existing_alias=""
  [[ -f "$f" ]] && existing_alias=$(_session_field "$f" ALIAS || true)

  local fresh=1
  [[ -f "$f" && -z "$existing_alias" ]] && fresh=0

  # Basename-collision warning (#165): the repo basename IS the PM's identity
  # (role = pm-<reponame>), so two different repos with the same basename
  # (…/a/api and …/b/api) would silently share one pm-api mailbox and address.
  # Compare canonical repo *roots* (RC-7), so worktrees of one repo — whose raw
  # REPO= paths differ — don't false-alarm, while genuinely different repos that
  # share a basename do. Warn loudly (log + stderr) but do NOT block: a moved or
  # renamed checkout hits this too, and blocking would strand the PM. Skip when
  # the prior file was an alias placeholder.
  if [[ -f "$f" && -z "$existing_alias" && -n "$repo" ]]; then
    local prev_repo prev_root new_root
    prev_repo=$(_session_field "$f" REPO || true)
    if [[ -n "$prev_repo" ]]; then
      prev_root=$(_repo_root_of "$prev_repo"); [[ -n "$prev_root" ]] || prev_root="$prev_repo"
      new_root=$(_repo_root_of "$repo");       [[ -n "$new_root"  ]] || new_root="$repo"
      if [[ "$prev_root" != "$new_root" ]]; then
        _log "register: WARNING basename collision role=$role existing_repo=$prev_repo new_repo=$repo"
        printf 'radio: WARNING — role %s is already registered for a different repo (%s); now claiming it for %s. Two repos with the same basename share one PM mailbox — rename one to disambiguate.\n' \
          "$role" "$prev_repo" "$repo" >&2
      fi
    fi
  fi

  # Re-register protection (#117): `SessionStart` fires again on `/compact`,
  # `/clear`, `/resume`, or a fresh `claude` in the same tab — each time
  # passing the original $ZELLIJ_TAB (the bare slug captured at pane creation).
  # By then `_rename_tab` has painted the visible name to "⏸️ <slug>" or
  # "▶️ <slug>", so a literal-name lookup misses and `tab_id` is empty. If we
  # blindly rewrote the session file we'd clobber a valid TAB_ID with "",
  # killing all subsequent _rename_tab repaints and cmd_send wake-ups for the
  # rest of the worker's life — and finally leaking the tab when task-done
  # reads the now-empty TAB_ID (#117). Preserve the existing TAB_ID instead.
  if [[ -z "$tab_id" ]]; then
    local existing_tab_id=""
    if [[ -f "$f" ]]; then
      existing_tab_id=$(_session_field "$f" TAB_ID || true)
    fi
    if [[ -n "$existing_tab_id" ]]; then
      tab_id="$existing_tab_id"
      # Preserve the recorded ZELLIJ_SESSION too, not just the id (#167 review
      # #3). Stamping the *current* session name onto a *preserved* (old) id
      # would launder the stale binding — recorded==current forever, defeating
      # the identity check for exactly the stale id it exists to catch.
      zsession=$(_session_field "$f" ZELLIJ_SESSION || true)
      _log "register: zellij list-tabs miss for tab=$tab — preserving existing TAB_ID=$tab_id session=$zsession role=$role"
    else
      _log "register: could not resolve tab_id for tab=$tab (zellij list-tabs returned no match)"
    fi
  fi

  # Persist the loadout and agent sidecars BEFORE the session file (#150
  # round-2 review: Finding 1; extended for AGENT in #151). If the process is
  # killed (OOM, task-done --force, host shutdown) between these writes, the
  # order matters:
  #
  #   sidecar-first (this order):
  #     pre-kill state:  .loadout=claude-gh, .agent=claude, .info absent
  #     re-seed reads:   sidecars → LOADOUT/AGENT recovered ✓
  #
  #   info-first (the OLD order — pre-#150-r3):
  #     pre-kill state:  .info has LOADOUT/AGENT, sidecars absent
  #     unregister cascade deletes .info; sidecars never existed
  #     re-seed reads:   no sidecar, hook subshell has no $TASK_FORCE_LOADOUT
  #                      / $TASK_FORCE_AGENT → LOADOUT=unknown / AGENT=claude ✗
  #
  # The window is microseconds wide, but the cascade in #140 makes it
  # statistically reachable. Reversing the order eliminates the failure mode
  # entirely. Skipping the loadout sidecar on empty $loadout keeps its mere
  # existence equivalent to "we have a real loadout to restore" — otherwise
  # a re-seed could read an empty sidecar and clobber the env-var fallback
  # that test paths still rely on. The agent sidecar is always written
  # because --agent is required (cmd_register exits 2 above if absent), so
  # $agent is always a real value here.
  if [[ -n "$loadout" ]]; then
    printf '%s' "$loadout" | _atomic_write "$(_loadout_sidecar "$role")"
  fi
  printf '%s' "$agent" | _atomic_write "$(_agent_sidecar "$role")"

  {
    printf 'ROLE=%s\nTAB=%s\nTAB_ID=%s\nZELLIJ_SESSION=%s\nREPO=%s\nREPO_NAME=%s\nSTATE=idle\nLAST_HEARTBEAT=%s\nAGENT=%s\nLOADOUT=%s\n' \
      "$role" "$tab" "$tab_id" "$zsession" "$repo" "$repo_name" "$(_now)" "$agent" "$loadout"
    # Persist the --auto opt-in (#128). task-work --auto exports
    # TASK_FORCE_AUTO_SUBMIT=1 into the tab's env; cmd_send reads AUTO_SUBMIT
    # off the recipient's session file and flips wake-up from LF (manual) to
    # CR (auto-submit). task-pm and default workers never export this, so
    # they keep the human-gated default. `if` rather than `&&` so the brace
    # group exits 0 even when the flag is absent — pipefail + set -e would
    # otherwise abort register on every non-auto worker.
    if [[ "${TASK_FORCE_AUTO_SUBMIT:-}" == "1" ]]; then
      printf 'AUTO_SUBMIT=1\n'
    fi
  } | _atomic_write "$f"

  mkdir -p "$(_inbox_dir "$role")" "$(_processed_dir "$role")"

  # Re-seed alias sessions from this primary's sidecar (#165 RC-4a). `task-pm
  # --also` recorded each alias here; SessionStart re-runs register on every
  # /compact / resume / restart, so recreating the alias .info files here gives
  # multi-repo routing the same self-heal the primary's own session enjoys — an
  # erroneous unregister sweep (the #140 cascade) or a plain restart no longer
  # silently drops it. Only a real primary (not an alias placeholder) re-seeds.
  if [[ -z "$existing_alias" ]]; then
    _reseed_aliases "$role"
  fi

  _log "register role=$role tab=$tab tab_id=$tab_id agent=$agent loadout=$loadout repo_name=$repo_name"

  # Legacy `pm` inbox adoption (#182): before the drain summary below, a fresh
  # pm-<reponame> register migrates any orphaned literal-`pm` backlog into this
  # role's inbox so the same drain that follows surfaces it. Runs BEFORE the gc
  # piggyback so that once we empty the legacy inbox, gc becomes free to reap the
  # dead `pm` mailbox (its _inbox_empty gate had been protecting it, #169). Gated
  # on the same fresh=1 / non-alias conditions as the drain: /compact/resume
  # re-registers and alias placeholders never adopt. now_epoch feeds the
  # "no live pm session" check inside the helper. `|| true` mirrors the gc
  # piggyback below: calling the helper in a `||` context disables set -e for its
  # whole body, so a stray mv/mkdir failure mid-migration can never abort register
  # (the drain summary still runs, just without the adopted messages).
  if (( fresh == 1 )) && [[ -z "$existing_alias" ]]; then
    _adopt_legacy_pm_inbox "$role" "$(date -u +%s)" || true
  fi

  # Amortized gc piggyback (#169): a fresh primary register runs a quiet
  # 14-day sweep so dead mailboxes / expired processed messages / an oversized
  # log never accumulate unbounded — no cron. Gated on fresh=1 so /compact /
  # resume re-registers don't re-sweep, and on an empty $existing_alias so an
  # alias placeholder doesn't. Our own mailbox + session file already exist
  # (written above), so this role is never its own target. Run in a subshell
  # with output suppressed: gc's stdout must not pollute the SessionStart
  # context injection (the drain summary below is the only thing that should),
  # and any nonzero exit inside gc must not abort register.
  #
  # Throttled to once per hour via a `.gc-last` sentinel (#184 review #4): gc
  # walks the ENTIRE global $MAILBOX_DIR (every repo, hundreds of dirs), and a
  # fleet of --auto workers fires SessionStart re-registers within seconds of
  # each other — so without the throttle each boot re-walks the whole tree. The
  # sentinel makes it genuinely amortized rather than per-register. A benign race
  # (two registers both seeing a stale sentinel) just runs gc twice; gc is
  # idempotent, so that's harmless.
  if (( fresh == 1 )) && [[ -z "$existing_alias" ]]; then
    local gc_sentinel="$RADIO_HOME/.gc-last" gc_last gc_now
    gc_now=$(date -u +%s)
    gc_last=$(_file_mtime "$gc_sentinel") || true
    if [[ -z "$gc_last" ]] || (( gc_now - gc_last >= 3600 )); then
      ( cmd_gc --max-age-days 14 ) >/dev/null 2>&1 || true
      : > "$gc_sentinel" 2>/dev/null || true
    fi
  fi

  # First paint of the idle prefix without waiting for a Stop hook cycle (#95).
  # _rename_tab reads $TASK_FORCE_ROLE, which the SessionStart hook sets to the
  # same value as --role here (`radio register --role $TASK_FORCE_ROLE …`).
  _rename_tab idle

  # Drain-on-register (#168): surface any messages that queued while this role
  # was offline. `radio send` makes exactly one wake attempt, at send time —
  # a report sent while the recipient isn't running (the "no session for pm"
  # strandings from the July investigation) just lands in the inbox with zero
  # redelivery. Nothing else surfaces that backlog at startup: the stop-hook
  # flush needs a Stop event and the prompt-hook injection needs a user
  # prompt, but register runs from SessionStart — whose stdout IS injected
  # into the model's context (claude loadouts only; Kiro's hook stdout isn't
  # injected, so this beat no-ops there — same #146 divergence as the stop-
  # and prompt-hook beats). Printing the backlog summary here puts it in front
  # of the agent on its very first turn, closing the offline→online gap — the
  # companion to the stop-hook flush (busy case) and prompt-hook injection
  # (idle case).
  #
  # Guards:
  #   - fresh=1 only: skip on re-register (#174 review Finding 1). Re-fires on
  #     /compact/clear/resume land here with the role already online, where
  #     "queued while offline" is false; the /clear context wipe is backstopped
  #     by prompt-hook on the next prompt.
  #   - Real register only: lives in cmd_register, NOT _ensure_session_file's
  #     re-seed path, so a busy/ready self-heal never re-prints (acceptance #3).
  #   - Empty inbox emits nothing (acceptance #2).
  #   - No-role SessionStart never reaches here — the dispatcher exits 0 before
  #     cmd_register when $TASK_FORCE_ROLE is unset (#93).
  local inbox
  inbox=$(_inbox_dir "$role")
  if (( fresh == 1 )) && [[ -d "$inbox" ]]; then
    shopt -s nullglob
    local msgs=("$inbox"/*.md)
    shopt -u nullglob
    if (( ${#msgs[@]} > 0 )); then
      _inbox_summary_joined "${msgs[@]}"   # sets INBOX_SUMMARY_N / INBOX_SUMMARY
      if (( INBOX_SUMMARY_N > 0 )); then
        # Recipe unified with prompt-hook's (#174 review Finding 2): `radio
        # check` only LISTS, and since #131 `radio read <id>` IS the ack, so an
        # agent told only to "process them" lists the backlog, treats it as
        # done, and never acks — leaving prompt-hook to re-inject the same ids
        # every turn. Naming `radio read <id>` is what actually drains the
        # queue. The backticks are literal markdown for the reading agent, not
        # command substitution.
        # shellcheck disable=SC2016
        printf '[radio] %s message(s) queued while this role was offline: %s. Run `radio check`, then process each with `radio read <id>` before taking new work.\n' \
          "$INBOX_SUMMARY_N" "$INBOX_SUMMARY"
        # Flag the legacy backfill (#182) so the reading PM knows some of these
        # were adopted from the orphaned literal-`pm` inbox (their header carries
        # an `adopted-from:` provenance line), not sent directly to this role.
        if (( ADOPTED_LEGACY_N > 0 )); then
          # shellcheck disable=SC2016
          printf '[radio] (%s of the above were adopted from the legacy `pm` inbox — see each message'\''s `adopted-from:` header.)\n' \
            "$ADOPTED_LEGACY_N"
        fi
        _log "register: surfaced $INBOX_SUMMARY_N queued message(s) role=$role"
      fi
    fi
  fi
}

# Register an alias session (#165): `task-pm --also <repo>` points a second
# repo's PM address at one running PM. The alias file carries ALIAS=pm-<primary>
# (+ REPO= for bookkeeping) and NO inbox — cmd_send follows the ALIAS= hop so a
# `--to pm-<other>` lands in the primary's single inbox and wakes its tab. One
# PM brain, one inbox, N repos.
cmd_register_alias() {
  local role="" target="" repo=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --role)   role="$2";   shift 2 ;;
      --alias)  target="$2"; shift 2 ;;
      --repo)   repo="$2";   shift 2 ;;
      *) echo "register-alias: unknown flag $1" >&2; exit 2 ;;
    esac
  done
  [[ -n "$role"   ]] || { echo "register-alias: --role required"  >&2; exit 2; }
  [[ -n "$target" ]] || { echo "register-alias: --alias required" >&2; exit 2; }
  _validate_role "$role"   || exit 2
  _validate_role "$target" || exit 2
  [[ "$role" != "$target" ]] || { echo "register-alias: an alias cannot point at itself ($role)" >&2; exit 2; }

  local f
  f=$(_session_file "$role")
  # Warn (don't block) on any overwrite of an existing session (RC-4d): a
  # non-alias session is a live PM/worker we'd hijack; an alias for a *different*
  # primary/repo is two clients' same-named repos silently last-write-winning.
  # Re-pointing the same alias at the same target/repo is idempotent (no warn).
  if [[ -f "$f" ]]; then
    local existing_alias existing_repo
    existing_alias=$(_session_field "$f" ALIAS || true)
    existing_repo=$(_session_field "$f" REPO || true)
    if [[ -z "$existing_alias" ]]; then
      _log "register-alias: WARNING overwriting non-alias session role=$role with alias -> $target"
      printf 'radio: WARNING — %s already had a live (non-alias) session; overwriting it with an alias → %s.\n' "$role" "$target" >&2
    elif [[ "$existing_alias" != "$target" || "$existing_repo" != "$repo" ]]; then
      _log "register-alias: WARNING re-pointing alias role=$role from $existing_alias($existing_repo) to $target($repo)"
      printf 'radio: WARNING — alias %s already pointed at %s (%s); re-pointing to %s (%s).\n' \
        "$role" "$existing_alias" "$existing_repo" "$target" "$repo" >&2
    fi
  fi

  {
    printf 'ROLE=%s\nALIAS=%s\nREPO=%s\nLAST_HEARTBEAT=%s\n' \
      "$role" "$target" "$repo" "$(_now)"
  } | _atomic_write "$f"

  # Migrate any inbox that queued at this address *before* it became an alias
  # (RC-4b): a worker that pinged pm-<other> while no PM ran left messages in
  # mailbox/pm-<other>/inbox; the alias owns no inbox, so nobody would ever
  # drain them. Fold them into the primary's single inbox now so the very
  # backlog the --also recovery flow exists to recover isn't stranded.
  local src_inbox dst_inbox moved=0
  src_inbox=$(_inbox_dir "$role")
  dst_inbox=$(_inbox_dir "$target")
  if [[ -d "$src_inbox" ]]; then
    mkdir -p "$dst_inbox"
    shopt -s nullglob
    local m
    for m in "$src_inbox"/*.md; do
      # `if` (not `&&`) so a failed mv can't abort under set -e, and so a
      # moved=0 arithmetic result below never exits 1 through the loop tail.
      if mv -f "$m" "$dst_inbox/" 2>/dev/null; then moved=$((moved+1)); fi
    done
    shopt -u nullglob
    rmdir "$src_inbox" 2>/dev/null || true
    rmdir "$(dirname "$src_inbox")" 2>/dev/null || true
    if (( moved > 0 )); then _log "register-alias: migrated $moved queued message(s) $role -> $target"; fi
  fi

  # Record in the primary's alias sidecar so its register re-seeds this alias
  # across /compact / restart (RC-4a). Rewrite (not skip-if-present) any existing
  # entry for this role so a re-point with a different --repo updates the line
  # the re-seed will replay — else the sidecar would resurrect the stale repo.
  local sc line
  sc=$(_aliases_sidecar "$target")
  {
    if [[ -f "$sc" ]]; then
      while IFS= read -r line; do
        [[ "$line" == "${role}|"* ]] && continue   # drop the old entry for this role
        printf '%s\n' "$line"
      done < "$sc"
    fi
    printf '%s|%s\n' "$role" "$repo"
  } | _atomic_write "$sc"

  _log "register-alias role=$role -> $target repo=$repo"
}

# Re-create a primary's alias sessions from its sidecar (#165 RC-4a). Called
# from cmd_register. Skips an address that a real (non-alias) session has since
# claimed, and an alias already pointing at us (idempotent).
_reseed_aliases() {
  local primary="$1" sc arole arepo
  sc=$(_aliases_sidecar "$primary")
  [[ -f "$sc" ]] || return 0
  while IFS='|' read -r arole arepo; do
    [[ -n "$arole" ]] || continue
    _validate_role "$arole" 2>/dev/null || continue
    local af cur
    af=$(_session_file "$arole")
    if [[ -f "$af" ]]; then
      cur=$(_session_field "$af" ALIAS || true)
      [[ "$cur" == "$primary" ]] || continue   # real session or foreign alias — leave it
    fi
    { printf 'ROLE=%s\nALIAS=%s\nREPO=%s\nLAST_HEARTBEAT=%s\n' "$arole" "$primary" "$arepo" "$(_now)"; } \
      | _atomic_write "$af"
  done < "$sc"
}

cmd_unregister() {
  _silent_exit_if_no_role
  _require_role

  # When invoked from Claude Code's SessionEnd hook, a JSON payload is piped
  # on stdin with a `reason` field. The hook fires on intra-session events
  # (reason=clear from `/clear`, reason=resume from `/compact` and session
  # resume) as well as on real exit (reason=logout|prompt_input_exit|other).
  # Without filtering we wipe the session file mid-life — empirically observed
  # as bursts of 40+ unregister calls within ~25s, with busy/ready calls
  # immediately afterwards logging "no session file" against the now-missing
  # file (#107 review).
  #
  # Manual invocations (e.g. from task-done, or a user typing `radio
  # unregister` in a shell) don't pipe a JSON payload — proceed unconditionally
  # in that case. We only filter when both (a) stdin is not a terminal and
  # (b) a parseable `reason` is present.
  if [[ ! -t 0 ]]; then
    local reason="" payload_oneline
    _read_hook_payload
    if [[ -n "$HOOK_PAYLOAD" ]] && command -v jq >/dev/null 2>&1; then
      reason=$(_hook_payload_field reason)
      case "$reason" in
        clear|resume)
          _log "unregister: skipping (reason=$reason — intra-session event) role=$TASK_FORCE_ROLE"
          return 0
          ;;
        "")
          # Cascade pattern (#151): payload is present but contains no
          # parseable `.reason` field. The PR-#150 diagnostic showed bursts of
          # 144 unregister calls in ~25s with payload literally "y" and
          # reason=<unset> — phantom invocations from somewhere upstream of
          # Claude Code's documented SessionEnd hook (which always includes
          # reason ∈ {clear, resume, logout, prompt_input_exit, other}).
          # Treat these the same as clear/resume: known non-real-exit events
          # that must not wipe the session file or the sidecars. Real exits
          # still flow through the logout/prompt_input_exit/other branches
          # below and clean up normally; manual invocations (no stdin) also
          # proceed because `[[ ! -t 0 ]]` is false then.
          payload_oneline=$(printf '%s' "$HOOK_PAYLOAD" | tr '\n' ' ' | tr -s ' ')
          _log "unregister: skipping (reason=<unset> — cascade, no real-exit signal) role=$TASK_FORCE_ROLE payload=$payload_oneline"
          return 0
          ;;
      esac
    fi
    # Instrumentation for #140: when the hook fires with a payload that
    # *doesn't* match the skip-list, capture the full payload so we can see
    # what reason (or non-reason) is driving the unregister cascade. Empirically
    # observed as bursts of 20+ unregister calls in ~30s on long-running
    # worker sessions; the root cause needs the payload to investigate. Log
    # is compacted to one line via tr so it doesn't fragment radio.log. Post-
    # #151, an empty reason is already short-circuited above, so this line
    # only fires for non-empty named reasons (logout, prompt_input_exit,
    # other, or anything new Claude Code adds in the future).
    if [[ -n "$HOOK_PAYLOAD" ]]; then
      payload_oneline=$(printf '%s' "$HOOK_PAYLOAD" | tr '\n' ' ' | tr -s ' ')
      _log "unregister: proceeding (reason=${reason:-<unset>}) role=$TASK_FORCE_ROLE payload=$payload_oneline"
    fi
  fi

  local f
  f=$(_session_file "$TASK_FORCE_ROLE")
  rm -f "$f"
  # Sweep the loadout + agent sidecars too — leaving them behind would let a
  # future _ensure_session_file resurrect a stale loadout / agent for a role
  # whose tab has really exited and been re-used (#140, #151).
  rm -f "$(_loadout_sidecar "$TASK_FORCE_ROLE")"
  rm -f "$(_agent_sidecar "$TASK_FORCE_ROLE")"

  # Sweep alias files pointing at this role (#165): `task-pm --also` created
  # pm-<other>.info with ALIAS=<this role>; they must not outlive their primary
  # (they'd dangle, routing sends into a dead inbox). Match on ALIAS= value. This
  # runs only on real exit / manual unregister — the intra-session cascade cases
  # returned early above — and the alias sidecar is re-seeded at the next
  # register, so an erroneous sweep self-heals (RC-4a). On a real exit we also
  # drop the sidecar so a later clean restart doesn't resurrect stale aliases.
  shopt -s nullglob
  local af at
  for af in "$SESSIONS_DIR"/*.info; do
    at=$(_session_field "$af" ALIAS || true)
    if [[ "$at" == "$TASK_FORCE_ROLE" ]]; then
      rm -f "$af"
      _log "unregister: swept alias $(basename "$af" .info) -> $TASK_FORCE_ROLE"
    fi
  done
  shopt -u nullglob
  rm -f "$(_aliases_sidecar "$TASK_FORCE_ROLE")"

  _log "unregister role=$TASK_FORCE_ROLE"
}

cmd_ready() { _hook_role_gate; _update_state idle; }
cmd_busy()  { _hook_role_gate; _update_state busy; }
cmd_awaiting() { _hook_role_gate; _update_state awaiting; }

# Stop-hook entrypoint (#163). `radio send` makes exactly one wake attempt, at
# send time — a message sent while the recipient is busy/awaiting queues with
# zero redelivery, and the old Stop hook (`radio ready && radio check`)
# couldn't fix that: Stop-hook stdout goes to the hook subshell, never to the
# model. Instead, when the inbox is non-empty we emit Claude Code's
# `{"decision": "block", ...}` JSON on stdout (with exit 0), which forces the
# agent to continue and drain the queue the moment its turn ends.
cmd_stop_hook() {
  _hook_role_gate

  # Count first, pure bash — the common case is an empty inbox, and this
  # ordering keeps the cat+jq spawns (below) entirely off that fast path
  # (#172 review). It also shrinks the code that runs before the state flip,
  # so a set -e failure mid-function is less likely to surface as a non-zero
  # exit — which the Stop-hook contract interprets as "block, with raw
  # stderr as the reason".
  local inbox n=0
  inbox=$(_inbox_dir "$TASK_FORCE_ROLE")
  if [[ -d "$inbox" ]]; then
    shopt -s nullglob
    local msgs=("$inbox"/*.md)
    shopt -u nullglob
    n=${#msgs[@]}
  fi

  if (( n == 0 )); then
    _update_state idle
    return 0
  fi

  # Fail SAFE without jq (#172 review): we can't read stop_hook_active, and
  # blocking blind could re-block on every Stop forever. jq-less hosts never
  # get zellij wakes either, so degrading to the old queue-only behavior is
  # consistent.
  if ! command -v jq >/dev/null 2>&1; then
    _log "stop-hook: jq unavailable — not blocking ($n unread) role=$TASK_FORCE_ROLE"
    _update_state idle
    return 0
  fi

  # Claude Code pipes the Stop-hook JSON payload on stdin. Manual invocations
  # from a terminal carry no payload — treat that (and a malformed payload)
  # as stop_hook_active=false. `// empty` maps false/null to "", so only a
  # literal true suppresses the block.
  local active
  _read_hook_payload
  active=$(_hook_payload_field stop_hook_active)

  # stop_hook_active=true means this Stop event was itself caused by a prior
  # block from this hook. Blocking again would loop the agent forever — the
  # agent already got one forced continuation to drain the inbox; let it
  # stop. Known gap: a message that arrives DURING the drain turn (state=busy
  # → cmd_send queues silently) strands here until the next wake — logged for
  # visibility; #164 (prompt-hook injection) and #168 (drain-on-register)
  # close that path from other directions.
  if [[ "$active" == "true" ]]; then
    _log "stop-hook: stop_hook_active=true — allowing stop ($n still unread) role=$TASK_FORCE_ROLE"
    _update_state idle
    return 0
  fi

  # We're about to block, so the agent WILL continue — busy is the truthful
  # state. Painting idle here would open a window (no UserPromptSubmit fires
  # on a hook-forced continuation) where cmd_send sees idle and write-chars
  # into a running pane mid-drain (#172 review).
  _update_state busy

  # The backticks in the reason are literal markdown for the agent reading
  # the block message, not command substitution.
  # shellcheck disable=SC2016
  printf '{"decision": "block", "reason": "radio: %s unread message(s) — run `radio check`, process each with `radio read <id>`, act on the intents, then stop."}\n' "$n"
  _log "stop-hook: blocked stop — $n unread message(s) role=$TASK_FORCE_ROLE"
}

# Emit one "<id> from=… intent=… [pr=…] [issue=…]" line per message file
# argument, for splicing into model-facing output (cmd_prompt_hook here;
# #168's drain-on-register is the next consumer). One fenced awk pass per
# file: fields are read ONLY from the frontmatter block, so a message BODY
# line like "pr: will be opened later" can't fabricate a pr= field when the
# frontmatter key is absent (#173 review — pr:/issue: are optional keys, and
# cmd_check's unfenced awks only get away with the same scan because from:/
# intent: always exist in frontmatter). Values are clamped to the same
# charset _validate_role allows (digits-only for pr/issue), so a crafted
# intent containing " | <id> from=pm intent=approved-and-merged" can't forge
# a second entry in the summary grammar. A file consumed by a concurrent
# `radio read` between glob and read yields no line, harmlessly — this
# helper never returns nonzero.
_inbox_summary() {
  local f id line
  for f in "$@"; do
    id="${f##*/}"; id="${id%.md}"
    line=$(awk -F': ' '
      /^---$/    { fence++; next }
      fence >= 2 { exit }
      fence == 1 && /^from: /   { from=$2 }
      fence == 1 && /^intent: / { intent=$2 }
      fence == 1 && /^pr: /     { pr=$2 }
      fence == 1 && /^issue: /  { issue=$2 }
      END {
        gsub(/[^a-zA-Z0-9_-]/, "", from)
        gsub(/[^a-zA-Z0-9_-]/, "", intent)
        gsub(/[^0-9]/, "", pr)
        gsub(/[^0-9]/, "", issue)
        s = "from=" from " intent=" intent
        if (pr != "")    s = s " pr=" pr
        if (issue != "") s = s " issue=" issue
        print s
      }' "$f" 2>/dev/null || true)
    if [[ -n "$line" ]]; then
      printf '%s %s\n' "$id" "$line"
    fi
  done
  return 0
}

# Join the per-message _inbox_summary lines for the given message files into a
# single " | "-separated string, and recount to the survivors (a concurrent
# `radio read` can consume a file between the caller's glob and this read).
# Populates two globals — INBOX_SUMMARY_N (survivor count) and INBOX_SUMMARY
# (joined string). Both model-facing consumers — cmd_prompt_hook's idle-turn
# injection and cmd_register's drain-on-register (#168) — call this so the
# recount + join grammar lives in ONE place; a format fix lands in both at
# once instead of drifting between two verbatim copies (#174 review Finding 3;
# the exact drift the #173 review predicted when it asked for _inbox_summary).
# Never returns nonzero. Callers own only their printf template.
INBOX_SUMMARY_N=0
INBOX_SUMMARY=""
_inbox_summary_joined() {
  INBOX_SUMMARY_N=0
  INBOX_SUMMARY=""
  local entries=() entry
  while IFS= read -r entry; do
    entries+=("$entry")
  done < <(_inbox_summary "$@")
  INBOX_SUMMARY_N=${#entries[@]}
  local summary=""
  for entry in "${entries[@]}"; do
    if [[ -n "$summary" ]]; then summary+=" | "; fi
    summary+="$entry"
  done
  INBOX_SUMMARY="$summary"
  return 0
}

# UserPromptSubmit-hook entrypoint (#164). Unlike Stop, a UserPromptSubmit
# hook's stdout IS injected into the model's context — which makes it the
# reliable delivery path for a backlog that queued while the recipient was
# idle and every send-time zellij wake failed (no writable pane, stale
# TAB_ID, missing session file: an idle agent fires no hooks, so those
# messages dangle until something else wakes it). Marks the role busy exactly
# like the `radio busy` hook it replaces, then prints a compact summary of
# any unread inbox. Empty inbox prints nothing — zero context noise.
#
# Fail open on EVERY path (#164 notes / #173 review): a nonzero exit here
# blocks and erases the user's typed prompt, which is strictly worse than
# any radio bookkeeping we could lose. Hence the _hook_role_gate and the
# `|| true` on _update_state.
cmd_prompt_hook() {
  _hook_role_gate

  # Busy FIRST, before any inbox work — truthful-state doctrine (#172): the
  # turn is starting now, and every instruction executed while the session
  # file still says idle is a window for cmd_send to write-chars into the
  # running pane. The `|| true` alone provides the fail-open behavior;
  # deferring the flip would buy nothing (#173 supplemental).
  _update_state busy || true

  # Count next, pure bash — this hook fires on every user prompt (the
  # hottest path in the system) and the common case is an empty inbox:
  # nothing spawned beyond _update_state, zero stdout.
  local inbox n=0
  inbox=$(_inbox_dir "$TASK_FORCE_ROLE")
  if [[ -d "$inbox" ]]; then
    shopt -s nullglob
    local msgs=("$inbox"/*.md)
    shopt -u nullglob
    n=${#msgs[@]}
  fi
  if (( n == 0 )); then
    return 0
  fi

  _inbox_summary_joined "${msgs[@]}"   # sets INBOX_SUMMARY_N / INBOX_SUMMARY
  n=$INBOX_SUMMARY_N                    # a concurrent radio read may have consumed some
  if (( n == 0 )); then
    return 0
  fi

  # The backticks are literal markdown for the agent reading the injected
  # context, not command substitution.
  # shellcheck disable=SC2016
  printf '[radio] %s unread message(s): %s. Process with `radio check` / `radio read <id>` before or after the user'\''s request, as appropriate.\n' \
    "$n" "$INBOX_SUMMARY"
  _log "prompt-hook: surfaced $n unread message(s) role=$TASK_FORCE_ROLE"
}

# Emit the "queued — idle but wake failed" outcome line (#166). Every wake miss
# after the recipient is confirmed idle funnels through here so the five reasons
# (no zellij, no tab, no TAB_ID, no pane, write-chars failed) share one wording.
# The #165 recipient-resolution note (`radio: --to pm → … (via …)`) is a separate
# line printed once in cmd_send, so the outcome lines here name the already-
# resolved role without needing a suffix of their own.
#
# The redelivery promise is agent-specific: claude has a prompt-hook + register
# drain, so a missed wake resurfaces on the recipient's next prompt/register;
# kiro has neither hook injected (#146), so soften to the neutral "check/register"
# rather than promise a prompt-hook that will never fire.
_send_outcome_wake_failed() {
  local to="$1" reason="$2" agent="${3:-}"
  local surface="prompt/register"
  [[ "$agent" == "kiro" ]] && surface="check/register"
  printf 'radio: queued — %s is idle but wake failed (%s); message will surface on its next %s\n' \
    "$to" "$reason" "$surface"
}

# Resolve a `--to pm` send to the repo-scoped PM role (#165). `pm` is the stable
# wire format — every prompt sends `--to pm` (never the expanded env var), so a
# single resolution path here covers every sender: new workers, pre-migration
# workers, reviewers, and env-less agents alike (#165 RC-1). The env var is a
# hint consumed *here*, registration-gated like every other step, so the injected
# path can't strand a message at an unregistered address while a live PM waits.
#
# Resolution order — each step wins only when its target is actually registered:
#   1. $TASK_FORCE_PM_ROLE          — launch-time identity, if that role is live
#   2. derive from the sender's identity (worker-<repo>-… / reviewer-<repo>-…):
#        a. the sender session's persisted REPO_NAME= (worktree-proof, RC-2),
#           falling back to basename(REPO=) for pre-RC-2 sessions
#        b. the longest registered `pm-<name>` whose <name> prefixes the sender's
#           slug (RC-3: longest-match, warn+queue on genuine ambiguity)
#   3. literal `pm` if a `pm.info` session still exists (pre-migration PM)
#   4. nothing registered — queue at the best *future* address (the env/derived
#      candidate) so the no-session WARNING names where a PM should register;
#      else literal `pm`.
# Records the resolved role in $_PM_RESOLVE_RESULT and the winning method in
# $_PM_RESOLVE_VIA (globals rather than stdout so cmd_send can read both without
# a command-substitution subshell — which would drop the _VIA assignment).
_PM_RESOLVE_RESULT=""
_PM_RESOLVE_VIA=""
_resolve_pm_target() {
  _PM_RESOLVE_RESULT="pm"
  _PM_RESOLVE_VIA=""
  local candidate=""

  # 1. launch-time identity — registration-gated (RC-1). A hand-exported,
  #    malformed $TASK_FORCE_PM_ROLE must not become the resolved target: it
  #    would trip cmd_send's post-shim `_validate_role || exit 2` (a hard fail
  #    the old wire format never had). Validate here and, on failure, ignore the
  #    env entirely — the send degrades to the same literal-`pm` queue as any
  #    other unresolvable case. The env value is otherwise the best *future*
  #    address, so remember it for the step-4 queue target.
  if [[ -n "${TASK_FORCE_PM_ROLE:-}" ]]; then
    if _validate_role "$TASK_FORCE_PM_ROLE" 2>/dev/null; then
      candidate="$TASK_FORCE_PM_ROLE"
      if [[ -f "$(_session_file "$candidate")" ]]; then
        _PM_RESOLVE_RESULT="$candidate"
        # shellcheck disable=SC2016  # literal label for the feedback line, not an expansion
        _PM_RESOLVE_VIA='$TASK_FORCE_PM_ROLE (registered)'
        return 0
      fi
    else
      _log "send: ignoring malformed \$TASK_FORCE_PM_ROLE=$TASK_FORCE_PM_ROLE"
    fi
  fi

  # 2. derive from the sender's own identity — also registration-gated.
  local sender="${TASK_FORCE_ROLE:-}"
  case "$sender" in
    worker-*|reviewer-*)
      # 2a. sender session persisted REPO_NAME= (worktree-proof), else legacy
      #     basename(REPO=) for sessions written before RC-2.
      local sf rn="" repo
      sf=$(_session_file "$sender")
      if [[ -f "$sf" ]]; then
        rn=$(_session_field "$sf" REPO_NAME || true)
        if [[ -z "$rn" ]]; then
          repo=$(_session_field "$sf" REPO || true)
          [[ -n "$repo" ]] && rn=$(_sanitize_role_segment "$(basename "$repo")")
        fi
      fi
      if [[ -n "$rn" ]]; then
        [[ -z "$candidate" ]] && candidate="pm-${rn}"
        if [[ -f "$(_session_file "pm-${rn}")" ]]; then
          _PM_RESOLVE_RESULT="pm-${rn}"
          _PM_RESOLVE_VIA="sender REPO_NAME=${rn}"
          return 0
        fi
      fi
      # 2b. longest registered pm-<name> whose <name> prefixes the sender slug.
      if _resolve_pm_by_slug_split "$sender"; then
        return 0
      fi
      ;;
  esac

  # 3. pre-migration literal pm (only reachable because no derived role was live)
  if [[ -f "$(_session_file pm)" ]]; then
    _PM_RESOLVE_RESULT="pm"
    _PM_RESOLVE_VIA="literal pm (pre-migration session)"
    return 0
  fi
  # 4. nothing registered — prefer the env/derived candidate as the queue target
  #    (correct future address; the no-session WARNING names it), else literal pm.
  if [[ -n "$candidate" ]]; then
    _PM_RESOLVE_RESULT="$candidate"
    _PM_RESOLVE_VIA="unregistered (${candidate})"
    return 0
  fi
  _PM_RESOLVE_RESULT="pm"
  _PM_RESOLVE_VIA="unresolved (literal pm fallback)"
  return 0
}

# RC-3: match the sender's slug against live pm-<name> sessions, preferring the
# LONGEST matching name so `api` and `api-server` both live don't let LC_COLLATE
# glob order silently decide which PM gets `worker-api-server-fix-1`'s reports.
# Two matches where neither name is a prefix of the other is genuine ambiguity:
# warn (log + stderr) and return non-zero so resolution falls through rather than
# guessing. Sets $_PM_RESOLVE_RESULT / $_PM_RESOLVE_VIA and returns 0 on a
# unique match; returns 1 otherwise.
_resolve_pm_by_slug_split() {
  local sender="$1"
  local rest="${sender#worker-}"; rest="${rest#reviewer-}"
  local pf name best="" ambiguous=0
  shopt -s nullglob
  for pf in "$SESSIONS_DIR"/pm-*.info; do
    name=$(basename "$pf" .info); name="${name#pm-}"
    [[ -n "$name" ]] || continue
    [[ "$rest" == "$name" || "$rest" == "$name-"* ]] || continue
    if [[ -z "$best" ]]; then
      best="$name"
    elif (( ${#name} > ${#best} )); then
      case "$name" in "$best"-*|"$best") best="$name" ;; *) ambiguous=1 ;; esac
    elif (( ${#name} < ${#best} )); then
      case "$best" in "$name"-*|"$name") : ;; *) ambiguous=1 ;; esac
    fi
  done
  shopt -u nullglob
  [[ -n "$best" ]] || return 1
  # Defensive net: two names that both prefix-match one slug are always nested
  # (the shorter is a prefix of the longer), so `ambiguous` is provably
  # unreachable under hyphen-boundary matching — longest-match alone decides.
  # Kept in case the match condition ever loosens.
  if (( ambiguous )); then
    _log "send: --to pm ambiguous for $sender — multiple non-nested pm-<name> matches; falling through"
    printf 'radio: WARNING — --to pm is ambiguous for %s (two overlapping pm-<name> sessions); not guessing. Send with an explicit --to pm-<name>.\n' "$sender" >&2
    return 1
  fi
  _PM_RESOLVE_RESULT="pm-${best}"
  _PM_RESOLVE_VIA="sender-role split (longest) → pm-${best}"
  return 0
}

cmd_send() {
  local to="" intent="" pr="" issue="" repo="" body=""
  local body_set=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --to)     to="$2";     shift 2 ;;
      --intent) intent="$2"; shift 2 ;;
      --pr)     pr="$2";     shift 2 ;;
      --issue)  issue="$2";  shift 2 ;;
      --repo)   repo="$2";   shift 2 ;;
      --body)   body="$2"; body_set=1; shift 2 ;;
      *) echo "send: unknown flag $1" >&2; exit 2 ;;
    esac
  done
  [[ -n "$to"     ]] || { echo "send: --to required"     >&2; exit 2; }
  [[ -n "$intent" ]] || { echo "send: --intent required" >&2; exit 2; }
  _validate_role "$to" || exit 2

  # --to pm compat shim (#165): resolve `pm` to the repo-scoped pm-<reponame>
  # role. `pm` is the stable wire format (RC-1), so this runs on every PM-bound
  # send. No-op for any explicitly-scoped target (pm-foo / worker-… / reviewer-…).
  local to_orig="$to" route_desc=""
  if [[ "$to" == "pm" ]]; then
    _resolve_pm_target
    to="$_PM_RESOLVE_RESULT"
    _validate_role "$to" || exit 2
    _log "send: --to pm resolved to $to (via ${_PM_RESOLVE_VIA})"
    route_desc="via ${_PM_RESOLVE_VIA}"
  fi
  # Alias hop (#165): an alias session file (written by `task-pm --also`)
  # carries ALIAS=pm-<primary> and owns no inbox — a message addressed to it
  # lands in the primary's single inbox and wakes the primary's tab. Follow
  # exactly one hop; a second hop is a misconfiguration, not a chain.
  local _alias_target
  _alias_target=$(_session_field "$(_session_file "$to")" ALIAS 2>/dev/null || true)
  if [[ -n "$_alias_target" ]]; then
    _validate_role "$_alias_target" || exit 2
    local _alias_hop2
    _alias_hop2=$(_session_field "$(_session_file "$_alias_target")" ALIAS 2>/dev/null || true)
    if [[ -n "$_alias_hop2" ]]; then
      echo "send: alias chain too deep ($to → $_alias_target → $_alias_hop2); refusing to route" >&2
      exit 2
    fi
    _log "send: alias hop $to -> $_alias_target"
    route_desc="${route_desc:+$route_desc, }via alias ${to}"
    to="$_alias_target"
  fi
  # Observability handshake with the #166 delivery feedback (RC-7): name the
  # resolved recipient and how we got there on EVERY shim invocation — including
  # the literal-pm and migration-fallback paths a postmortem needs — so the
  # sender is never left guessing where its ping actually went.
  if [[ -n "$route_desc" ]]; then
    printf 'radio: --to %s → %s (%s)\n' "$to_orig" "$to" "$route_desc"
  fi

  local from="${TASK_FORCE_ROLE:-unknown}"
  local id
  id="$(_compact_now)-from-${from}-$(_rand_id)"
  local inbox
  inbox=$(_inbox_dir "$to")
  mkdir -p "$inbox"
  local msg="$inbox/${id}.md"

  if [[ "$body_set" -eq 0 ]] && [[ ! -t 0 ]]; then
    body=$(cat)
  fi

  {
    printf -- '---\n'
    printf 'id: %s\n' "$id"
    printf 'from: %s\n' "$from"
    printf 'to: %s\n' "$to"
    printf 'intent: %s\n' "$intent"
    [[ -n "$pr"    ]] && printf 'pr: %s\n'    "$pr"
    [[ -n "$issue" ]] && printf 'issue: %s\n' "$issue"
    [[ -n "$repo"  ]] && printf 'repo: %s\n'  "$repo"
    printf 'created_at: %s\n' "$(_now)"
    printf -- '---\n'
    printf '%s\n' "$body"
  } | _atomic_write "$msg"

  _log "send id=$id from=$from to=$to intent=$intent"

  # Report the delivery outcome on stdout so the sending agent knows what
  # actually happened (#166). `radio send` prints nothing today, so a queued
  # send behind a busy — or entirely absent — recipient looks identical to a
  # live wake. Four honest outcomes, all exit 0 (queuing is legitimate); usage
  # errors above still exit 2.
  #
  # The session-file check comes first — "nobody is listening" is the most
  # important signal, and it doesn't depend on the sender being inside zellij.
  local rs
  rs=$(_session_file "$to")
  if [[ ! -f "$rs" ]]; then
    _log "send: no session for $to — message queued (id=$id)"
    printf 'radio: WARNING — no session for %s; message queued but nobody is listening. Verify the role name (ls ~/.task-force/radio/sessions/) or start the recipient.\n' "$to"
    return 0
  fi
  local rstate rtab ragent
  rstate=$(_session_field "$rs" STATE || true)
  rtab=$(_session_field "$rs" TAB || true)
  ragent=$(_session_field "$rs" AGENT || true)
  if [[ "$rstate" != "idle" ]]; then
    # Dead-but-non-idle: a crashed tab leaves STATE=busy/awaiting forever (the
    # `radio orphans` case). If the heartbeat is >1h stale (same threshold as
    # `radio orphans`), the "drains on its next Stop" promise is a lie — no Stop
    # is coming — so escalate to a warning instead of falsely reassuring the
    # sender. Full self-heal of the stale session stays #127's job.
    local hb hb_epoch now_epoch age
    hb=$(_session_field "$rs" LAST_HEARTBEAT || true)
    hb_epoch=$(_iso_to_epoch "$hb")
    now_epoch=$(date -u +%s)
    if [[ -n "$hb_epoch" ]] && (( now_epoch - hb_epoch > 3600 )); then
      age=$(( now_epoch - hb_epoch ))
      _log "send: $to looks dead (state=$rstate, heartbeat ${age}s stale) — queued (id=$id)"
      # shellcheck disable=SC2016  # backticks are literal output, not a subshell
      printf 'radio: WARNING — %s looks dead (state=%s, heartbeat %ss stale); message queued but it may not be listening. See `radio orphans`.\n' "$to" "$rstate" "$age"
      return 0
    fi
    # An `awaiting` agent's turn is already over — no Stop event is coming, and
    # the drain path is prompt-hook after the human responds. Don't promise a
    # Stop that won't happen; the honest signal is different from `busy`.
    if [[ "$rstate" == "awaiting" ]]; then
      _log "send: $to is awaiting (state=$rstate) — queued (id=$id)"
      printf 'radio: queued — %s is awaiting user input; it will surface via prompt-hook when next prompted\n' "$to"
      return 0
    fi
    _log "send: $to is busy (state=$rstate) — queued (id=$id)"
    printf 'radio: queued — %s is busy; it will drain on its next Stop\n' "$to"
    return 0
  fi
  # Recipient is registered and idle from here on. Any failure to wake it is a
  # transient wake miss, not a "nobody home" — the message surfaces on the
  # recipient's next prompt-hook / register. Report the reason honestly.
  if [[ -z "${ZELLIJ:-}" ]]; then
    _log "send: \$ZELLIJ unset — skipping zellij wake (id=$id)"
    _send_outcome_wake_failed "$to" "sender is not in a zellij session" "$ragent"
    return 0
  fi
  if [[ -z "$rtab" ]]; then
    _log "send: $to has no TAB — queued (id=$id)"
    _send_outcome_wake_failed "$to" "recipient has no tab" "$ragent"
    return 0
  fi
  # Wake-up via per-pane targeting (#102): write to a pane on the recipient's
  # own tab, never the focused tab. The tab address comes from _live_tab_id
  # (#167), which trusts the recorded TAB_ID only when the tab still at that id
  # still bears the recipient's bare name — so a TAB_ID that outlived a zellij
  # restart, or belongs to a sibling server, can't misdeliver "radio check"
  # into an unrelated pane. An empty recorded TAB_ID means the recipient
  # registered in a non-zellij context — nothing to wake, queue and move on.
  local rtab_id rpane_id rc
  rtab_id=$(_session_field "$rs" TAB_ID || true)
  if [[ -z "$rtab_id" ]]; then
    _log "send: $to has no TAB_ID (not zellij-registered?) — queued (id=$id)"
    _send_outcome_wake_failed "$to" "not zellij-registered" "$ragent"
    return 0
  fi
  # rc capture guarded against set -e (non-zero rc 1/3 from _live_tab_id).
  rc=0
  rtab_id=$(_live_tab_id "$rs" "$(_strip_tab_prefix "$rtab")") || rc=$?
  if [[ "$rc" -eq 1 || -z "$rtab_id" ]]; then
    _log "send: $to tab id unresolved — stale/gone or owner alive in another zellij server — queued (id=$id)"
    _send_outcome_wake_failed "$to" "stale or unreachable tab" "$ragent"
    return 0
  fi
  # Recovered a fresh id by name (recorded id was stale/gone) — repair the file
  # so subsequent sends are id-driven again (#167).
  if [[ "$rc" -eq 3 ]]; then
    _repair_tab_binding "$rs" "$rtab_id"
    _log "send: $to recovered stale tab id by name → tab_id=$rtab_id (id=$id)"
  fi
  rpane_id=$(_zellij_pane_in_tab "$rtab_id")
  if [[ -z "$rpane_id" ]]; then
    _log "send: no writable pane on tab_id=$rtab_id for $to — queued (id=$id)"
    _send_outcome_wake_failed "$to" "no writable pane on its tab" "$ragent"
    return 0
  fi
  # Only ever write the literal string "radio check<term>" — never the message
  # body or any caller-supplied data. `zellij write-chars` injects directly
  # into the recipient's TUI input buffer; writing anything else risks
  # corrupting the agent's unsaved prompt or smuggling content into a TUI
  # command. The recipient reads the actual message via `radio check` /
  # `radio read`.
  #
  # Recipients launched via `task-work --auto` opt in to CR (auto-submit) so
  # PM pings process without a manual Enter (#128). Everyone else — PM,
  # default workers, pre-#128 workers with no AUTO_SUBMIT field — gets LF,
  # which lands "radio check" in the input box and waits for the user to
  # press Enter. The human gate is what protects partially-typed prompts
  # from being corrupted by an incoming wake-up.
  local wake_term=$'\n'
  if [[ "$(_session_field "$rs" AUTO_SUBMIT || true)" == "1" ]]; then
    wake_term=$'\r'
  fi
  zellij action write-chars --pane-id "$rpane_id" "radio check${wake_term}" >/dev/null 2>&1 || {
    _log "send: write-chars failed for $to (pane=$rpane_id) — queued (id=$id)"
    _send_outcome_wake_failed "$to" "write-chars failed" "$ragent"
    return 0; }
  _log "send: woke $to via tab_id=$rtab_id pane=$rpane_id (id=$id)"
  printf 'radio: delivered — woke %s (tab_id=%s)\n' "$to" "$rtab_id"
}

cmd_check() {
  _silent_exit_if_no_role
  _require_role
  local inbox
  inbox=$(_inbox_dir "$TASK_FORCE_ROLE")
  [[ -d "$inbox" ]] || { mkdir -p "$inbox"; return 0; }
  shopt -s nullglob
  local any=0
  for f in "$inbox"/*.md; do
    any=1
    local id from intent oneline
    id=$(basename "$f" .md)
    from=$(awk -F': ' '/^from:/{print $2; exit}' "$f")
    intent=$(awk -F': ' '/^intent:/{print $2; exit}' "$f")
    # First non-frontmatter, non-blank line:
    oneline=$(awk '/^---$/ { f++; next } f >= 2 && NF { print; exit }' "$f")
    printf '%s\tfrom=%s\tintent=%s\t%s\n' "$id" "$from" "$intent" "$oneline"
  done
  shopt -u nullglob
  [[ "$any" -eq 1 ]] || echo "(no unread messages)"
}

cmd_read() {
  _require_role
  # Default beat is read+ack: print body, then move inbox -> processed. The
  # split between `read` and `ack` was a footgun — workers would `read`, act,
  # and forget to `ack`, leaving stale messages that re-listed on every
  # `radio check` (see #131). `--peek` / `--no-ack` is the escape hatch for
  # inspection without consuming.
  local peek=0
  local id=""
  while (($#)); do
    case "$1" in
      --peek|--no-ack) peek=1; shift ;;
      --) shift; break ;;
      -*) echo "read: unknown flag $1" >&2; exit 2 ;;
      *) id="$1"; shift ;;
    esac
  done
  [[ -n "$id" ]] || { echo "read: <id> required" >&2; exit 2; }
  local inbox processed
  inbox=$(_inbox_dir "$TASK_FORCE_ROLE")
  processed=$(_processed_dir "$TASK_FORCE_ROLE")
  local src="$inbox/${id}.md"
  local in_inbox=1
  if [[ ! -f "$src" ]]; then
    src="$processed/${id}.md"
    in_inbox=0
  fi
  [[ -f "$src" ]] || { echo "read: message $id not found" >&2; exit 1; }
  cat "$src"
  if (( peek == 0 )) && (( in_inbox == 1 )); then
    mkdir -p "$processed"
    mv -f "$src" "$processed/"
    _log "read+ack id=$id role=$TASK_FORCE_ROLE"
  fi
}

cmd_ack() {
  _require_role
  local id="${1:-}"
  [[ -n "$id" ]] || { echo "ack: <id> required" >&2; exit 2; }
  local inbox processed
  inbox=$(_inbox_dir "$TASK_FORCE_ROLE")
  processed=$(_processed_dir "$TASK_FORCE_ROLE")
  local src="$inbox/${id}.md"
  # Idempotent: if `read` already auto-acked (post-#131), exit 0 quietly so
  # existing `read && ack` scripts and muscle memory don't break.
  if [[ ! -f "$src" ]]; then
    if [[ -f "$processed/${id}.md" ]]; then
      echo "ack: message $id already processed"
      return 0
    fi
    echo "ack: message $id not in inbox" >&2
    exit 1
  fi
  mkdir -p "$processed"
  mv -f "$src" "$processed/"
  _log "ack id=$id role=$TASK_FORCE_ROLE"
}

cmd_orphans() {
  [[ -d "$SESSIONS_DIR" ]] || return 0
  local now_epoch
  now_epoch=$(date -u +%s)
  shopt -s nullglob
  for f in "$SESSIONS_DIR"/*.info; do
    local hb hb_epoch role age alias_target
    role=$(_session_field "$f" ROLE || basename "$f" .info)
    # Alias sessions (#165) carry no heartbeat of their own — they're stale
    # exactly when their target session has gone away (a normal primary
    # unregister sweeps them, so a dangling alias means an unclean exit).
    alias_target=$(_session_field "$f" ALIAS || true)
    if [[ -n "$alias_target" ]]; then
      if [[ ! -f "$(_session_file "$alias_target")" ]]; then
        printf '%s\t(alias → %s: target session missing)\n' "$role" "$alias_target"
      fi
      continue
    fi
    hb=$(_session_field "$f" LAST_HEARTBEAT || true)
    if [[ -z "$hb" ]]; then
      printf '%s\t(no LAST_HEARTBEAT)\n' "$role"
      continue
    fi
    hb_epoch=$(_iso_to_epoch "$hb")
    hb_epoch=${hb_epoch:-0}
    age=$(( now_epoch - hb_epoch ))
    if (( age > 3600 )); then
      printf '%s\tage=%ss\thb=%s\n' "$role" "$age" "$hb"
    fi
  done
  shopt -u nullglob
}

# Garbage-collect the radio home (#169): drop expired processed messages, reclaim
# whole mailbox dirs for roles that are dead (no session file OR >1h-stale
# heartbeat) AND hold no unread mail AND are quiescent (newest entry older than
# the cutoff), and rotate the log. The empty-inbox gate is load-bearing: it keeps
# gc from destroying undelivered mail — notably the legacy `pm` backlog #182 is
# deferred to adopt (post-#165 nothing registers as literal `pm`, so its inbox is
# write-only until then). Amortized via a throttled piggyback on cmd_register — no
# cron needed. `--dry-run` reports without touching anything; `--max-age-days N`
# (default 14) sets the cutoff.
cmd_gc() {
  local dry_run=0 max_age_days=14
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)      dry_run=1; shift ;;
      --max-age-days) max_age_days="$2"; shift 2 ;;
      *) echo "gc: unknown flag $1" >&2; exit 2 ;;
    esac
  done
  case "$max_age_days" in
    ''|*[!0-9]*) echo "gc: --max-age-days must be a non-negative integer" >&2; exit 2 ;;
  esac

  local now_epoch cutoff pfx=""
  now_epoch=$(date -u +%s)
  cutoff=$(( now_epoch - max_age_days * 86400 ))
  (( dry_run )) && pfx="[dry-run] "

  local removed_dirs=0 removed_msgs=0

  if [[ -d "$MAILBOX_DIR" ]]; then
    shopt -s nullglob
    local roledir role newest f m
    for roledir in "$MAILBOX_DIR"/*/; do
      roledir="${roledir%/}"
      role=$(basename "$roledir")
      # Whole-dir reclaim, all three conditions required: the role is dead
      # (no session file OR >1h-stale heartbeat, per _session_dead), its inbox
      # holds NO unread mail (_inbox_empty — the #182 backlog guard), and its
      # newest surviving entry has aged past the cutoff. Any one failing drops us
      # to the processed-only sweep below, which never touches inbox.
      if _session_dead "$role" "$now_epoch" && _inbox_empty "$role"; then
        newest=$(_newest_mtime_in "$roledir" "$now_epoch")
        if (( newest <= cutoff )); then
          echo "${pfx}remove dead mailbox: $role"
          if (( ! dry_run )); then
            rm -rf "$roledir"
            _log "gc: removed dead mailbox role=$role"
          fi
          removed_dirs=$(( removed_dirs + 1 ))
          continue
        fi
      fi
      # Live role, or a dead role still holding unread/fresh mail: expire only its
      # processed/ messages older than the cutoff. Inbox is never touched — unread
      # mail outlives gc. An unreadable mtime (empty from _file_mtime) is kept, not
      # swept (#184 review #2: a stat hiccup must not delete mail).
      for f in "$roledir"/processed/*; do
        [[ -f "$f" ]] || continue
        m=$(_file_mtime "$f") || true
        [[ -n "$m" ]] || continue
        if (( m <= cutoff )); then
          echo "${pfx}remove old processed: $role/$(basename "$f")"
          if (( ! dry_run )); then
            rm -f "$f"
            _log "gc: removed processed role=$role msg=$(basename "$f")"
          fi
          removed_msgs=$(( removed_msgs + 1 ))
        fi
      done
    done
    shopt -u nullglob
  fi

  # Rotate the log on a real run only — --dry-run touches nothing on disk.
  (( dry_run )) || _rotate_log

  echo "${pfx}gc: $removed_dirs dead mailbox(es), $removed_msgs processed message(s) (max-age ${max_age_days}d)"
}

# ----- dispatch -------------------------------------------------------------

mkdir -p "$SESSIONS_DIR" "$MAILBOX_DIR"
sub="${1:-}"
[[ -n "$sub" ]] || usage
shift || true
case "$sub" in
  send)        cmd_send "$@" ;;
  check)       cmd_check ;;
  read)        cmd_read "$@" ;;
  ack)         cmd_ack "$@" ;;
  # Dispatcher gate (#93): the SessionStart hook fires `register --role $TASK_FORCE_ROLE`,
  # which substitutes to `--role ""` when the env var is unset (plain `claude`
  # session in a task-force-equipped repo). Silently no-op in that case rather
  # than erroring out. A user invoking `radio register` directly will normally
  # have $TASK_FORCE_ROLE set (from task-work / task-pm), so they still hit the
  # loud `register: --role required` / `--agent required` errors in cmd_register
  # if they forget a flag — typo protection preserved.
  register)    [[ -z "${TASK_FORCE_ROLE:-}" ]] && exit 0; cmd_register "$@" ;;
  register-alias) cmd_register_alias "$@" ;;
  ready)       cmd_ready ;;
  busy)        cmd_busy ;;
  awaiting)    cmd_awaiting ;;
  stop-hook)   cmd_stop_hook ;;
  prompt-hook) cmd_prompt_hook ;;
  unregister)  cmd_unregister ;;
  orphans)     cmd_orphans ;;
  gc)          cmd_gc "$@" ;;
  -h|--help)   usage 0 ;;
  *) echo "radio: unknown subcommand '$sub'" >&2; usage 1 ;;
esac
