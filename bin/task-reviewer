#!/usr/bin/env bash
# `set -E` (errtrace) makes the ERR trap below inherit into `aw_launch_tab`
# and other sourced library functions — without it, a zellij `new-tab`
# failure inside `aw_launch_tab` would exit the script via `set -e` but skip
# the partial-state cleanup trap, leaving the worktree/branch/info file
# behind. (PR #139 round-4 review.)
set -eEuo pipefail

# task-reviewer — canonical entry point for all loadouts (#170).
#
# The claude body (shared by claude-gh / claude-jira / claude-notion /
# claude-local, formerly 4 byte-identical per-loadout copies) lives inline
# below; kiro-* impls are still routed to <impl>/bin/task-reviewer until the
# kiro variants converge (#146). Impl resolution comes from
# lib/detect-impl.sh — override with --impl <name> or AW_IMPL=<name>.

src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  dir=$(cd -P "$(dirname "$src")" && pwd)
  src=$(readlink "$src")
  [[ $src != /* ]] && src="$dir/$src"
done
BIN_DIR=$(cd -P "$(dirname "$src")" && pwd)
AW_ROOT=$(dirname "$BIN_DIR")

# shellcheck source=lib/detect-impl.sh
source "$AW_ROOT/lib/detect-impl.sh"

# The claude flow spawns a fresh zellij tab + git worktree on the PR's head
# ref, then runs `claude /reviewer <pr-url> [<issue-url>]` inside it. The
# reviewer reads the spec issue (if any), the PR diff, runs the code-review
# skill, posts a single thorough PR comment, and radios PM back with a
# verdict.
#
# Replaces the previous in-place-tab-takeover model (#138). PM stays on its
# tab — the reviewer worker is ephemeral, one per review.

# shellcheck source=lib/zellij-tab.sh
source "$AW_ROOT/lib/zellij-tab.sh"
# shellcheck source=lib/worktree-create.sh
source "$AW_ROOT/lib/worktree-create.sh"
# shellcheck source=lib/repo-name.sh
source "$AW_ROOT/lib/repo-name.sh"

usage() {
  cat <<'EOF'
Usage:
  task-reviewer <pr-url-or-number> [<issue-url-or-number>] [options]

Spawns a fresh zellij tab + git worktree on the PR's head ref, then runs the
/reviewer slash command. The reviewer reads the spec issue (for compliance
cross-check), the PR diff, runs the code-review skill, posts a single thorough
PR comment, and radios PM back with a verdict — clean or with findings.

Positional arguments:
  <pr-url-or-number>      The PR to review. Accepts a GitHub PR URL or a bare
                          number (resolved in the current repo's `origin`).
  <spec-identifier>       Optional — the spec this PR claims to close.
                          Shape depends on the loadout:
                            claude-gh     — issue number or GitHub issue URL.
                                            If omitted, auto-detected from the
                                            PR body's Closes/Fixes/Resolves #N.
                            claude-jira   — Jira issue key (e.g. PROJ-123).
                            claude-notion — Notion page URL.
                            claude-local  — local task slug or filename.
                          PR-body auto-detect is GitHub-only — non-gh loadouts
                          must pass the 2nd arg explicitly. With no spec id,
                          the reviewer proceeds with a diff-only review.

Options:
      --no-auto           Opt out of --permission-mode auto. Default is auto
                          because the /reviewer prompt's authority boundaries
                          rule out anything destructive (no merge, no push, no
                          Status edits) — running the review hands-off matches
                          the "dispatch and walk away" goal of this command.
      --no-launch         Open the worktree tab but do NOT start claude.
  -h, --help              Show this help.

Environment:
  ANTHROPIC_MODEL         Defaults to claude-sonnet-4-6 (cheap orchestrator).
                          Pre-set to override (e.g. claude-opus-4-7 for a
                          one-off premium pass).

Examples:
  task-reviewer 42
  task-reviewer https://github.com/owner/repo/pull/42
  task-reviewer 42 38
  task-reviewer https://github.com/owner/repo/pull/42 38 --no-auto
EOF
  exit "${1:-1}"
}

# ---------------- impl resolution + kiro routing ----------------
aw_parse_impl_flag "$@" || exit 1

if ! IMPL=$(aw_detect_impl "$AW_PARSED_IMPL"); then
  # No impl resolvable (outside a git repo / no workflow doc) — aw_detect_impl
  # already printed why. Still honor an explicit help request so
  # `task-reviewer --help` works anywhere.
  for arg in ${AW_REMAINING_ARGS[@]+"${AW_REMAINING_ARGS[@]}"}; do
    case "$arg" in -h|--help) usage 0 ;; esac
  done
  exit 1
fi

if [[ "$IMPL" == kiro-* ]]; then
  TARGET="$AW_ROOT/$IMPL/bin/task-reviewer"
  if [[ ! -x "$TARGET" ]]; then
    # The reviewer role ships for all claude loadouts and kiro-gh. Surface
    # that explicitly rather than a generic "not found" message — the impl is
    # configured, the *reviewer* just isn't part of it (#146 tracks parity).
    echo "Error: task-reviewer is not available for impl '$IMPL'." >&2
    echo "       Reviewer support currently ships for claude-gh, claude-jira," >&2
    echo "       claude-notion, claude-local, and kiro-gh." >&2
    echo "       See https://github.com/martin-conur/task-force/issues/146 for tracking." >&2
    exit 1
  fi
  exec "$TARGET" ${AW_REMAINING_ARGS[@]+"${AW_REMAINING_ARGS[@]}"}
fi

# The claude body branches on the impl's tracker suffix (gh / jira / notion /
# local) for tracker-aware behavior — only the gh tracker resolves spec issues
# via the GitHub `Closes #N` convention; the others accept any opaque 2nd
# positional arg (Jira key, Notion URL, local slug) and pass it through to
# /reviewer untouched (#144). Keying on the suffix rather than the full impl
# name means a future kiro-* body reuse (#146) or new loadout (#92) inherits
# the right tracker behavior for free.
TRACKER="${IMPL##*-}"

# Continue with --impl (and its value) stripped from the argv.
set -- ${AW_REMAINING_ARGS[@]+"${AW_REMAINING_ARGS[@]}"}

# ---------------- arg parsing ----------------
# --auto is the default — the reviewer is always a dispatched worker and the
# /reviewer prompt's authority list explicitly rules out merge/push/approve/
# close/Status. Defeats the hands-off-dispatch goal of #138 to make every
# review require manual permission-clicks. `--no-auto` is the explicit opt-out
# for callers who want the interactive path.
POSITIONAL=()
NO_LAUNCH=""
AUTO_MODE="1"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage 0 ;;
    --auto) AUTO_MODE="1"; shift ;;
    --no-auto) AUTO_MODE=""; shift ;;
    --no-launch) NO_LAUNCH="1"; shift ;;
    --) shift; while [[ $# -gt 0 ]]; do POSITIONAL+=("$1"); shift; done ;;
    -*) echo "Error: unknown flag '$1'" >&2; usage 1 ;;
    *) POSITIONAL+=("$1"); shift ;;
  esac
done

[[ ${#POSITIONAL[@]} -lt 1 ]] && { echo "Error: PR url or number is required" >&2; usage 1; }

parse_pr_number() {
  local input="$1"
  if [[ "$input" =~ ^[0-9]+$ ]]; then
    echo "$input"; return 0
  fi
  if [[ "$input" == *"github.com"*"/pull/"* ]]; then
    echo "$input" | sed 's|.*/pull/||' | sed 's|[^0-9].*||'
    return 0
  fi
  return 1
}

# Spec identifier parsing is tracker-aware. claude-gh keeps numeric / GitHub
# issue URL parsing. claude-jira / claude-notion / claude-local accept any
# non-empty string and pass it through opaquely — the /reviewer prompt knows
# how to resolve it via the loadout-appropriate MCP / file read.
parse_issue_number() {
  local input="$1"
  if [[ "$TRACKER" == "gh" ]]; then
    if [[ "$input" =~ ^[0-9]+$ ]]; then
      echo "$input"; return 0
    fi
    if [[ "$input" == *"github.com"*"/issues/"* ]]; then
      echo "$input" | sed 's|.*/issues/||' | sed 's|[^0-9].*||'
      return 0
    fi
    return 1
  fi
  [[ -n "$input" ]] || return 1
  printf '%s\n' "$input"
}

PR_INPUT="${POSITIONAL[0]}"
ISSUE_INPUT="${POSITIONAL[1]:-}"

PR_NUMBER=$(parse_pr_number "$PR_INPUT") || {
  echo "Error: could not parse PR number from '$PR_INPUT'" >&2
  exit 1
}

# ---------------- repo discovery ----------------
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || { echo "Error: not in a git repo" >&2; exit 1; }
REPO_NAME=$(basename "$REPO_ROOT")
WORKTREE_BASE="${REPO_ROOT}/../${REPO_NAME}-worktrees"
# Worktree-proof main-repo name for radio roles (#165 RC-2): task-reviewer runs
# "from any spare tab" which may itself be a linked worktree, where
# basename(REPO_ROOT) is the worktree slug. Derive the main repo name for the
# reviewer role and the injected PM address.
REPO_RADIO_NAME=$(aw_main_repo_name "$REPO_ROOT")

# ---------------- PR validation + metadata ----------------
# Validate PR exists. gh's built-in --jq flag avoids depending on a system
# jq install — gh ships gojq internally.
PR_URL=$(gh pr view "$PR_NUMBER" --json url --jq .url 2>/dev/null) || {
  echo "Error: PR #$PR_NUMBER not found (or gh failed)." >&2
  exit 1
}

PR_BASE_REF=$(gh pr view "$PR_NUMBER" --json baseRefName --jq .baseRefName 2>/dev/null || echo "main")
PR_BODY=$(gh pr view "$PR_NUMBER" --json body --jq .body 2>/dev/null || echo "")

# Spec identifier resolution:
#   - explicit 2nd arg always wins (parsed by tracker-aware parse_issue_number)
#   - claude-gh additionally falls back to scanning the PR body for
#     Closes/Fixes/Resolves #N (the GitHub linking convention)
#   - non-gh loadouts have no PR-body convention to scan — Jira keys / Notion
#     URLs / local slugs don't appear in PR bodies in a standard form — so
#     the 2nd positional arg is the only path (#144).
#
# ISSUE_NUMBER is the raw identifier (numeric for gh, opaque string elsewhere)
# persisted into the .info file for task-done. SPEC_IDENTIFIER is what
# /reviewer receives as $ARGUMENTS[1] (a GitHub issues URL for gh, the opaque
# identifier as-is for others).
ISSUE_NUMBER=""
SPEC_IDENTIFIER=""
if [[ -n "$ISSUE_INPUT" ]]; then
  # Only claude-gh's parse_issue_number can fail with a non-empty input
  # (numeric / URL parse rejection). Non-gh accepts any non-empty string,
  # and the [[ -n "$ISSUE_INPUT" ]] guard above means parse_issue_number
  # is never called with an empty input — so the failure path here is
  # claude-gh-only (#144 round-5).
  ISSUE_NUMBER=$(parse_issue_number "$ISSUE_INPUT") || {
    echo "Error: could not parse issue number from '$ISSUE_INPUT'" >&2
    exit 1
  }
  if [[ "$TRACKER" == "gh" ]]; then
    [[ "$ISSUE_INPUT" == *"github.com"* ]] && SPEC_IDENTIFIER="$ISSUE_INPUT"
  else
    SPEC_IDENTIFIER="$ISSUE_INPUT"
  fi
elif [[ "$TRACKER" == "gh" && -n "$PR_BODY" ]]; then
  ISSUE_NUMBER=$(printf '%s\n' "$PR_BODY" \
    | grep -iEo '(close[sd]?|fix(e[sd])?|resolve[sd]?)[[:space:]]+#[0-9]+' \
    | head -1 | grep -Eo '[0-9]+' || true)
fi

# claude-gh: synthesize the GitHub issues URL from PR_URL + ISSUE_NUMBER when
# the caller passed only a number (or we auto-detected from the body).
if [[ "$TRACKER" == "gh" && -n "$ISSUE_NUMBER" && -z "$SPEC_IDENTIFIER" && -n "$PR_URL" ]]; then
  SPEC_IDENTIFIER=$(printf '%s\n' "$PR_URL" | sed "s|/pull/[0-9]*|/issues/$ISSUE_NUMBER|")
fi

if [[ -z "$ISSUE_NUMBER" ]]; then
  if [[ "$TRACKER" == "gh" ]]; then
    echo "⚠ No spec issue associated with PR #$PR_NUMBER (no second arg, no Closes/Fixes in body)." >&2
  else
    echo "⚠ No spec identifier passed for PR #$PR_NUMBER." >&2
    echo "  PR-body auto-detect is GitHub-only — pass the spec id (Jira key, Notion URL," >&2
    echo "  local task slug) as the 2nd positional arg to enable spec-compliance review." >&2
  fi
  echo "  Reviewer will proceed with a diff-only review." >&2
fi

# ---------------- worktree setup ----------------
SLUG="review-pr${PR_NUMBER}"
# Branch is prefixed `task/` so `task-done`'s `${BRANCH#task/}` slug-strip
# yields `review-pr<N>` — matching the worktree dir and info file. Without
# the `task/` prefix `task-done --remove-worktree` reads a nonsense info
# path and leaks the worktree (PR #139 review).
BRANCH="task/review-pr${PR_NUMBER}"
WORKTREE_DIR="${WORKTREE_BASE}/${SLUG}"

# Concurrent-reviews guard: refuse with a clear error rather than silently
# spawning a parallel session or appending a suffix. The reviewer worktree is
# ephemeral and per-PR; two of them on the same PR is almost always a mistake
# (#138 open Q4). The branch check catches the stale-branch-without-directory
# case: if a user manually deletes the worktree dir but the
# `task/review-pr<N>` ref survives, `aw_create_worktree` would silently reuse
# it (emitting a stderr warning the dispatched reviewer never reads) and the
# review would open on stale code instead of the PR head. Refusing here forces
# an explicit `git branch -D task/review-pr<N>` cleanup instead.
if [[ -d "$WORKTREE_DIR" ]] || git show-ref --verify --quiet "refs/heads/$BRANCH"; then
  echo "Error: a review worktree or branch already exists for PR #$PR_NUMBER:" >&2
  [[ -d "$WORKTREE_DIR" ]] && echo "       worktree dir: $WORKTREE_DIR" >&2
  git show-ref --verify --quiet "refs/heads/$BRANCH" && echo "       branch:       $BRANCH" >&2
  echo "       Close that tab and run 'task-done --remove-worktree' to clean up," >&2
  echo "       or (branch-only case) 'git branch -D $BRANCH' to delete the stale ref." >&2
  exit 1
fi

# Fetch the PR head so the worktree can fork from it. If origin isn't
# configured or the fetch fails (offline, test env), fall back to HEAD with a
# soft warning — `gh pr diff` still works over the API for the review itself.
FROM_REF="HEAD"
if git fetch origin "pull/${PR_NUMBER}/head" --quiet 2>/dev/null; then
  FROM_REF="FETCH_HEAD"
else
  echo "⚠ Could not fetch PR #$PR_NUMBER's head ref — using current HEAD as the worktree base." >&2
  echo "  This is fine for review-only work (gh pr diff hits the API directly)." >&2
fi

mkdir -p "$WORKTREE_BASE"
INFO_FILE="${WORKTREE_BASE}/.${SLUG}.info"

# Cleanup trap: if anything between here and the successful `aw_launch_tab`
# below errors out (worktree create, fetch, info write, tab spawn), unwind
# the partial state so the next invocation isn't permanently blocked by the
# concurrent-reviews guard above. Without this, a single failed dispatch
# (e.g. zellij not running) would leave the worktree + branch + info file
# behind and the user would have to manually `git worktree remove + git
# branch -D + rm .info` before retrying. Trap is `RETURN`-cleared right
# after the successful launch so any downstream non-fatal stderr from
# `aw_zellij_tab_id_by_name` doesn't accidentally wipe the just-spawned
# worktree. (PR #139 round-4 review.)
_reviewer_cleanup_partial() {
  git worktree remove --force "$WORKTREE_DIR" 2>/dev/null || true
  git branch -D "$BRANCH" 2>/dev/null || true
  rm -f "$INFO_FILE"
}
trap _reviewer_cleanup_partial ERR

echo "Creating branch $BRANCH and worktree at $WORKTREE_DIR..."
aw_create_worktree "$WORKTREE_DIR" "$BRANCH" "$FROM_REF"

# Write info file so task-done can clean up the worktree when the user
# decides to (the reviewer never auto-removes — the tab stays open showing
# the analysis until manually closed; #138 open Q1+Q2).
BASE_BRANCH="${PR_BASE_REF:-main}"
{
  printf 'BASE_BRANCH=%s\n' "$BASE_BRANCH"
  printf 'SLUG=%s\n' "$SLUG"
  printf 'GH_URL=%s\n' "$PR_URL"
  printf 'PR_NUMBER=%s\n' "$PR_NUMBER"
  printf 'ISSUE_NUMBER=%s\n' "$ISSUE_NUMBER"
} > "$INFO_FILE"

# ---------------- claude command builder ----------------
build_claude_cmd() {
  local mode_prefix=""
  [[ -n "$AUTO_MODE" ]] && mode_prefix="--permission-mode auto "
  local slash_args="$PR_URL"
  # printf %q the user-supplied SPEC_IDENTIFIER so `$var`, `$(...)`, and
  # other metacharacters in non-gh tracker identifiers (Jira keys, Notion
  # URLs, local slugs) survive the `bash -ic` re-parse without being
  # expanded by the child shell. Mirrors how RADIO_ENV_PREFIX values are
  # already protected. `set +H` in the launch-site prefix handles `!`
  # history expansion; printf %q closes the rest of the metachar class.
  # (#144 round-5 review.)
  [[ -n "$SPEC_IDENTIFIER" ]] && slash_args+=" $(printf %q "$SPEC_IDENTIFIER")"
  echo "claude ${mode_prefix}\"/reviewer $slash_args\""
}

# ---------------- radio env injection ----------------
# Per-PR role so concurrent reviewers don't collide on the radio mailbox.
# Sonnet by default for the orchestrator (preserves #134 cost win); a
# pre-set ANTHROPIC_MODEL wins so the caller can pin Opus for a one-off.
TASK_FORCE_ROLE_VALUE="reviewer-${REPO_RADIO_NAME}-pr${PR_NUMBER}"
RESOLVED_MODEL="${ANTHROPIC_MODEL:-claude-sonnet-4-6}"
RADIO_ENV_PREFIX="TASK_FORCE_ROLE=$(printf %q "$TASK_FORCE_ROLE_VALUE") "
RADIO_ENV_PREFIX+="ZELLIJ_TAB=$(printf %q "$SLUG") "
RADIO_ENV_PREFIX+="TASK_FORCE_LOADOUT=reviewer "
RADIO_ENV_PREFIX+="ANTHROPIC_MODEL=$(printf %q "$RESOLVED_MODEL") "
# Repo-scoped PM address (#165): the reviewer radios its verdict with `--to pm`,
# resolved by radio's shim; this injected value is the shim's registration-gated
# launch-time identity so the verdict reaches THIS repo's PM (pm-<reponame>).
RADIO_ENV_PREFIX+="TASK_FORCE_PM_ROLE=$(printf %q "pm-${REPO_RADIO_NAME}") "
[[ -n "$AUTO_MODE" ]] && RADIO_ENV_PREFIX+="TASK_FORCE_AUTO_SUBMIT=1 "

# ---------------- launch ----------------
# 4th arg to aw_launch_tab is `stay_on_caller_tab=1` — keep focus on the
# caller's tab (PM or wherever this was dispatched from) instead of snapping
# into the new reviewer tab. Same convention task-work --auto adopted in
# #133; reviewer always opts in since it's always a dispatched worker.
#
# `set +H; ` prefix disables bash history expansion in the spawned `bash -ic`
# subshell — defends against SPEC_IDENTIFIER values containing `!` (Jira /
# Notion / local slugs with `auth-login!v2` shape, etc.) from being silently
# history-substituted before /reviewer ever sees the arg. Critically, this
# prefix must come BEFORE $RADIO_ENV_PREFIX, not inside build_claude_cmd's
# output, because `VAR=val cmd; cmd2` scopes VAR=val to `cmd` only — putting
# `set +H` between RADIO_ENV_PREFIX and `claude` would attach the env
# assignments to the `set` builtin and they'd never reach `claude` after the
# `;` (radio routing, model selection, AUTO_SUBMIT all dead). (#144 round-3.)
echo "Opening zellij tab '$SLUG'..."
if [[ -n "$NO_LAUNCH" ]]; then
  aw_launch_tab "$SLUG" "$WORKTREE_DIR" "" "1"
  echo "Tab opened at $WORKTREE_DIR — claude NOT launched (--no-launch)."
else
  aw_launch_tab "$SLUG" "$WORKTREE_DIR" "set +H; ${RADIO_ENV_PREFIX}$(build_claude_cmd)" "1"
  echo "Started reviewer in $WORKTREE_DIR for PR #$PR_NUMBER (issue: ${ISSUE_NUMBER:-none}, model: $RESOLVED_MODEL)"
fi

# Disarm the partial-state cleanup trap — the worktree is live, the tab is
# spawned, and downstream best-effort steps (aw_zellij_tab_id_by_name) must
# not roll the spawn back if they fail. Anything that goes wrong now is the
# user's tab to deal with.
trap - ERR

# Persist the zellij tab_id so task-done can scope close-tab-by-id to this
# reviewer's tab (same pattern task-work uses for workers).
INFO_TAB_ID=$(aw_zellij_tab_id_by_name "$SLUG" || true)
if [[ -n "$INFO_TAB_ID" ]]; then
  printf 'TAB_ID=%s\n' "$INFO_TAB_ID" >> "$INFO_FILE"
fi
