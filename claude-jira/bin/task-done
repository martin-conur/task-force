#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: task-done [--force]"
  echo ""
  echo "Run from within a worktree to:"
  echo "  1. Show the diff and print a gh PR command"
  echo "  2. Remove the worktree"
  echo "  3. Close the zellij tab"
  echo ""
  echo "Options:"
  echo "  --force    Skip confirmation prompts"
  exit 1
}

FORCE=false
[[ "${1:-}" == "--force" ]] && FORCE=true
[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && usage

WORKTREE_DIR=$(pwd)
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || { echo "Error: not in a git repo"; exit 1; }

# Check we're actually in a worktree (not the main repo)
MAIN_WORKTREE=$(git worktree list --porcelain | head -1 | sed 's/worktree //')
if [[ "$REPO_ROOT" == "$MAIN_WORKTREE" ]]; then
  echo "Error: you're in the main repo, not a worktree. cd into a worktree first."
  exit 1
fi

BRANCH=$(git rev-parse --abbrev-ref HEAD)
echo "Worktree: $WORKTREE_DIR"
echo "Branch:   $BRANCH"
echo ""

# Uncommitted changes?
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "⚠ Uncommitted changes detected:"
  git status --short
  echo ""
  if [[ "$FORCE" != true ]]; then
    read -rp "Continue anyway? (y/N) " confirm
    [[ "$confirm" != "y" && "$confirm" != "Y" ]] && exit 1
  fi
fi

COMMIT_COUNT=$(git rev-list --count main..HEAD 2>/dev/null || echo "?")
echo "Commits ahead of main: $COMMIT_COUNT"
echo ""

# Build PR title — uppercase the slug if it looks like a Jira key
SLUG="${BRANCH#task/}"
if [[ "$SLUG" =~ ^([a-z][a-z0-9_]+-[0-9]+)$ ]]; then
  PR_TITLE=$(echo "$SLUG" | tr '[:lower:]' '[:upper:]')
else
  PR_TITLE="$SLUG"
fi

echo "To create a PR:"
echo "  gh pr create --base main --head $BRANCH --title \"$PR_TITLE\" --fill"
echo ""

if [[ "$FORCE" != true ]]; then
  read -rp "Remove worktree and close tab? (y/N) " confirm
  [[ "$confirm" != "y" && "$confirm" != "Y" ]] && exit 0
fi

cd "$MAIN_WORKTREE"

echo "Removing worktree..."
git worktree remove "$WORKTREE_DIR" --force 2>/dev/null || {
  echo "Warning: could not remove worktree cleanly. Trying prune..."
  rm -rf "$WORKTREE_DIR"
  git worktree prune
}

echo "Closing zellij tab..."
zellij action close-tab

echo "Done. Branch '$BRANCH' still exists — delete after PR merge with: git branch -d $BRANCH"
