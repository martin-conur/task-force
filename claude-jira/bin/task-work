#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: task-work <jira-key-or-url-or-slug>"
  echo ""
  echo "Creates a git worktree + branch for a task and opens a new zellij tab"
  echo "with a Claude Code worker session."
  echo ""
  echo "Examples:"
  echo "  task-work PROJ-123"
  echo "  task-work https://your.atlassian.net/browse/PROJ-123"
  echo "  task-work add-store-filtering"
  exit 1
}

[[ $# -lt 1 || "${1:-}" == "--help" || "${1:-}" == "-h" ]] && usage

INPUT="$1"
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || { echo "Error: not in a git repo"; exit 1; }
REPO_NAME=$(basename "$REPO_ROOT")
WORKTREE_BASE="${REPO_ROOT}/../${REPO_NAME}-worktrees"

# Extract Jira key (if any) and the reference string we'll pass to the worker
JIRA_REF=""
if [[ "$INPUT" =~ atlassian\.net/browse/([A-Z][A-Z0-9_]+-[0-9]+) ]]; then
  JIRA_KEY="${BASH_REMATCH[1]}"
  JIRA_REF="$INPUT"
  SLUG=$(echo "$JIRA_KEY" | tr '[:upper:]' '[:lower:]')
elif [[ "$INPUT" =~ ^([A-Z][A-Z0-9_]+-[0-9]+)$ ]]; then
  JIRA_KEY="${BASH_REMATCH[1]}"
  JIRA_REF="$JIRA_KEY"
  SLUG=$(echo "$JIRA_KEY" | tr '[:upper:]' '[:lower:]')
else
  SLUG=$(echo "$INPUT" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | sed 's/[^a-z0-9-]//g')
  JIRA_REF=""
fi

SLUG="${SLUG:0:50}"
BRANCH="task/${SLUG}"
WORKTREE_DIR="${WORKTREE_BASE}/${SLUG}"

launch_worker() {
  local dir="$1"
  sleep 0.5
  if [[ -n "$JIRA_REF" ]]; then
    zellij action write-chars "cd $dir && claude \"/worker Implement Jira issue: $JIRA_REF\""
  else
    zellij action write-chars "cd $dir && claude \"/worker\""
  fi
  sleep 0.1
  zellij action write 10  # Enter
}

# Worktree already exists?
if [[ -d "$WORKTREE_DIR" ]]; then
  echo "Worktree already exists at $WORKTREE_DIR"
  zellij action go-to-tab-name "$SLUG" 2>/dev/null || {
    echo "Tab not found. Opening new tab..."
    zellij action new-tab --name "$SLUG"
    launch_worker "$WORKTREE_DIR"
  }
  exit 0
fi

mkdir -p "$WORKTREE_BASE"
echo "Creating branch $BRANCH and worktree at $WORKTREE_DIR..."
git worktree add "$WORKTREE_DIR" -b "$BRANCH" 2>/dev/null || {
  git worktree add "$WORKTREE_DIR" "$BRANCH" 2>/dev/null || {
    echo "Error: could not create worktree. Check if branch '$BRANCH' exists elsewhere."
    exit 1
  }
}

echo "Opening zellij tab '$SLUG'..."
zellij action new-tab --name "$SLUG"
launch_worker "$WORKTREE_DIR"

echo "Worker started in $WORKTREE_DIR (branch: $BRANCH)"
