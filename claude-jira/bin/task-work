#!/usr/bin/env bash
set -euo pipefail

# Source shared zellij tab launcher.
AW_ROOT_REAL="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
# shellcheck source=lib/zellij-tab.sh
source "$AW_ROOT_REAL/lib/zellij-tab.sh"

usage() {
  echo "Usage: task-work [options] <jira-key-or-url-or-slug>"
  echo ""
  echo "Creates a git worktree + branch for a task and opens a new zellij tab"
  echo "with a Claude Code worker session."
  echo ""
  echo "Options:"
  echo "  -b, --base BRANCH   Base branch for the PR (default: current branch)"
  echo "  -h, --help          Show this help"
  echo ""
  echo "Examples:"
  echo "  task-work PROJ-123"
  echo "  task-work https://your.atlassian.net/browse/PROJ-123"
  echo "  task-work add-store-filtering"
  echo "  task-work --base develop PROJ-456"
  exit 1
}

BASE_BRANCH_OVERRIDE=""
POSITIONAL=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    -b|--base)
      [[ $# -ge 2 ]] || { echo "Error: --base requires a value" >&2; exit 1; }
      BASE_BRANCH_OVERRIDE="$2"; shift 2 ;;
    -*) echo "Error: unknown flag '$1'" >&2; usage ;;
    *) POSITIONAL+=("$1"); shift ;;
  esac
done

[[ ${#POSITIONAL[@]} -lt 1 ]] && usage

INPUT="${POSITIONAL[0]}"
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || { echo "Error: not in a git repo"; exit 1; }
REPO_NAME=$(basename "$REPO_ROOT")
WORKTREE_BASE="${REPO_ROOT}/../${REPO_NAME}-worktrees"

# Capture base branch before any git operations
BASE_BRANCH="${BASE_BRANCH_OVERRIDE:-$(git rev-parse --abbrev-ref HEAD)}"

# Extract Jira key (if any) and the reference string we'll pass to the worker
JIRA_REF=""
if [[ "$INPUT" =~ atlassian\.net/browse/([A-Z][A-Z0-9_]+-[0-9]+) ]]; then
  JIRA_KEY="${BASH_REMATCH[1]}"
  JIRA_REF="$INPUT"
  SLUG=$(echo "$JIRA_KEY" | tr '[:upper:]' '[:lower:]')
elif [[ "$INPUT" =~ ^([A-Z][A-Z0-9_]+-[0-9]+)$ ]]; then
  JIRA_KEY="${BASH_REMATCH[1]}"
  JIRA_REF="$JIRA_KEY"
  SLUG=$(echo "$JIRA_KEY" | tr '[:upper:]' '[:lower:]')
else
  SLUG=$(echo "$INPUT" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | sed 's/[^a-z0-9-]//g')
  JIRA_REF=""
fi

SLUG="${SLUG:0:50}"
BRANCH="task/${SLUG}"
WORKTREE_DIR="${WORKTREE_BASE}/${SLUG}"

build_claude_cmd() {
  if [[ -n "$JIRA_REF" ]]; then
    echo "claude \"/worker Implement Jira issue: $JIRA_REF\""
  else
    echo "claude \"/worker\""
  fi
}

# Worktree already exists for this Jira key? Spin up a parallel session
# with a short hash suffix so multiple agents can iterate on the same ticket.
if [[ -d "$WORKTREE_DIR" ]]; then
  HASH=$(LC_ALL=C tr -dc 'a-z0-9' </dev/urandom | head -c 5 || :)
  SLUG="${SLUG}-${HASH}"
  BRANCH="task/${SLUG}"
  WORKTREE_DIR="${WORKTREE_BASE}/${SLUG}"
  echo "Existing worktree found for that Jira key — creating a parallel session: $SLUG"
fi

mkdir -p "$WORKTREE_BASE"
echo "Creating branch $BRANCH and worktree at $WORKTREE_DIR..."
git worktree add "$WORKTREE_DIR" -b "$BRANCH" 2>/dev/null || {
  git worktree add "$WORKTREE_DIR" "$BRANCH" 2>/dev/null || {
    echo "Error: could not create worktree. Check if branch '$BRANCH' exists elsewhere."
    exit 1
  }
}

# Write task info so the worker and task-done can read it (stored outside the working tree)
INFO_FILE="${WORKTREE_BASE}/.${SLUG}.info"
printf 'BASE_BRANCH=%s\nSLUG=%s\nJIRA_REF=%s\n' "$BASE_BRANCH" "$SLUG" "$JIRA_REF" > "$INFO_FILE"

echo "Opening zellij tab '$SLUG'..."
aw_launch_tab "$SLUG" "$WORKTREE_DIR" "$(build_claude_cmd)"

echo "Worker started in $WORKTREE_DIR (branch: $BRANCH, base: $BASE_BRANCH)"
