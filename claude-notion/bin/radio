#!/usr/bin/env bash
# region:body
# radio — tiny mailbox + zellij wake-up CLI for PM <-> worker handoff.
# See issue #63 for design.
set -euo pipefail

RADIO_HOME="${TASK_FORCE_HOME:-$HOME/.task-force}/radio"
SESSIONS_DIR="$RADIO_HOME/sessions"
MAILBOX_DIR="$RADIO_HOME/mailbox"
LOG_FILE="$RADIO_HOME/log"

usage() {
  cat <<'EOF'
Usage:
  radio send --to ROLE --intent KIND [--pr N] [--issue N] [--repo PATH] [--body TEXT | < body]
  radio check                            list unread messages for this role
  radio read   <id>                      print message body
  radio ack    <id>                      move message to processed/
  radio register --role ROLE --tab TAB [--repo PATH] --agent claude|kiro [--loadout NAME]
  radio ready                            mark this role idle (and process pending)
  radio busy                             mark this role busy
  radio unregister                       remove this role's session file
  radio orphans                          list session files with stale (>1h) heartbeat

Self-identification: every command except `register` reads $TASK_FORCE_ROLE.
Override the mailbox root with $TASK_FORCE_HOME (defaults to ~/.task-force).
EOF
  exit "${1:-1}"
}

# ----- helpers --------------------------------------------------------------

_log() {
  mkdir -p "$RADIO_HOME"
  printf '%s %s\n' "$(_now)" "$*" >>"$LOG_FILE"
}

_now() { date -u +%Y-%m-%dT%H:%M:%SZ; }

_compact_now() { date -u +%Y%m%d-%H%M%S; }

_rand_id() {
  # 32 bytes of /dev/urandom is plenty for 6 alphanumeric chars after `tr`
  # filtering — the previous 256-byte read was wasteful, not wrong.
  LC_ALL=C head -c 32 /dev/urandom | LC_ALL=C tr -dc 'a-z0-9' | head -c 6
}

_require_role() {
  if [[ -z "${TASK_FORCE_ROLE:-}" ]]; then
    echo "Error: \$TASK_FORCE_ROLE is not set (task-work / task-pm should set it)" >&2
    exit 2
  fi
  _validate_role "$TASK_FORCE_ROLE" || exit 2
}

# Silent no-op for hook-invoked commands when $TASK_FORCE_ROLE is unset (#93):
# plain `claude` in a task-force-equipped repo fires SessionStart/UserPromptSubmit/Stop
# hooks with no role, and the hooks have nothing to mutate. Exiting non-zero
# here would block UserPromptSubmit; exit 0 silently instead.
_silent_exit_if_no_role() {
  [[ -z "${TASK_FORCE_ROLE:-}" ]] && exit 0
  return 0
}

# Atomic write: stage into <file>.tmp.<rand> then rename. mv on POSIX is atomic
# within the same directory, so readers never see a half-written session file.
_atomic_write() {
  local target="$1" tmp
  tmp="${target}.tmp.$$.$RANDOM"
  mkdir -p "$(dirname "$target")"
  cat >"$tmp"
  mv -f "$tmp" "$target"
}

# Read a single KEY=VALUE field from a session file. Never `source` the file
# (it's untrusted input from another process); grep+cut is enough.
_session_field() {
  local file="$1" key="$2"
  [[ -f "$file" ]] || return 1
  local line
  line=$(grep -E "^${key}=" "$file" | head -1) || return 1
  printf '%s' "${line#*=}"
}

# Reject role names that could let a caller escape $SESSIONS_DIR / $MAILBOX_DIR
# via `..` or `/`. Today roles come from task-work / task-pm (`worker-<basename>-<slug>`
# and `pm`), so the values are already safe — but `_session_file` / `_inbox_dir`
# build paths by string concatenation, so we validate at the boundary
# (`_require_role` for self-identifying commands; `cmd_send` for `--to`) before
# any path is constructed.
_validate_role() {
  local role="$1"
  case "$role" in
    ""|*..*|*/*) echo "radio: invalid role: $role" >&2; return 1 ;;
    *[!a-zA-Z0-9_-]*) echo "radio: invalid role: $role" >&2; return 1 ;;
  esac
}

# Strip the idle/busy emoji prefix that `_rename_tab` paints onto TAB= so we
# can compare against $ZELLIJ_TAB (the bare slug set by task-work / task-pm at
# pane creation time) and surface the underlying name for callers that need it.
_strip_tab_prefix() {
  local s="$1"
  s="${s#⏸️ }"
  s="${s#▶️ }"
  printf '%s' "$s"
}

# Resolve a zellij tab's stable id from its visible name. Empty stdout means
# "lookup failed" (zellij not reachable, jq absent, name not found) — callers
# must treat that as a hard skip so we never operate on the wrong tab (#102).
_zellij_tab_id_by_name() {
  local target="$1"
  [[ -n "$target" ]] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  zellij action list-tabs --json 2>/dev/null \
    | jq -r --arg n "$target" \
        '[.[] | select(.name == $n) | .tab_id] | .[0] // empty' 2>/dev/null
}

# Pick a writable pane on the given tab. Prefer the tab's own focused pane
# (where the user's keyboard sits when they switch over); fall back to any
# non-plugin pane on that tab. Empty stdout means "no usable pane" — caller
# must skip rather than write to the focused tab's pane by accident (#102).
_zellij_pane_in_tab() {
  local target="$1"
  case "$target" in *[!0-9]*|"") return 0 ;; esac
  command -v jq >/dev/null 2>&1 || return 0
  zellij action list-panes --json --tab 2>/dev/null \
    | jq -r --argjson t "$target" '
        [.[] | select(.tab_id == $t and (.is_plugin // false) == false)]
        | (map(select(.is_focused == true))[0] // .[0]) | .id // empty
      ' 2>/dev/null
}

_session_file() {
  printf '%s/%s.info' "$SESSIONS_DIR" "$1"
}

_inbox_dir()    { printf '%s/%s/inbox'     "$MAILBOX_DIR" "$1"; }
_processed_dir(){ printf '%s/%s/processed' "$MAILBOX_DIR" "$1"; }

# Update STATE=… and LAST_HEARTBEAT=… on the current session file.
_update_state() {
  local new_state="$1"
  _require_role
  local f
  f=$(_session_file "$TASK_FORCE_ROLE")
  [[ -f "$f" ]] || { _log "update_state: no session file for $TASK_FORCE_ROLE"; return 0; }

  # Re-emit the file with STATE/LAST_HEARTBEAT replaced; preserve everything else.
  awk -v st="$new_state" -v hb="$(_now)" '
    BEGIN { OFS="=" }
    /^STATE=/         { print "STATE=" st;        seen_state=1; next }
    /^LAST_HEARTBEAT=/{ print "LAST_HEARTBEAT=" hb; seen_hb=1;  next }
    { print }
    END {
      if (!seen_state) print "STATE=" st
      if (!seen_hb)    print "LAST_HEARTBEAT=" hb
    }
  ' "$f" | _atomic_write "$f"

  _rename_tab "$new_state"
}

# Prefix the role's recorded zellij tab with an emoji reflecting STATE. No-op
# silently if zellij isn't running, $ZELLIJ is unset, we have no TAB= in the
# session file, or the calling pane is on a different tab than the role's tab
# (defense in depth — see the $ZELLIJ_TAB safeguard below). On success, also
# rewrite TAB= in the session file so subsequent lookups match the visible
# tab name (#95, #102).
_rename_tab() {
  local new_state="$1"
  [[ -n "${ZELLIJ:-}" ]] || return 0
  command -v zellij >/dev/null 2>&1 || return 0
  [[ -n "${TASK_FORCE_ROLE:-}" ]] || return 0

  local f current bare prefix new_name
  f=$(_session_file "$TASK_FORCE_ROLE")
  [[ -f "$f" ]] || return 0

  current=$(_session_field "$f" TAB || true)
  [[ -n "$current" ]] || return 0

  # Strip any existing emoji prefix so repeated calls don't stack them (e.g.
  # the previous run persisted `⏸️ pm` into TAB=; without stripping we'd
  # rename to `⏸️ ⏸️ pm`).
  bare=$(_strip_tab_prefix "$current")

  # Defense-in-depth safeguard (#102): if the caller's pane lives on a tab
  # other than the role's tab, refuse to rename. $ZELLIJ_TAB is set by
  # task-work / task-pm to the bare slug at pane creation and never mutates,
  # so it stays a stable comparison point even after we paint emoji prefixes
  # onto the visible name. This catches `TASK_FORCE_ROLE=other radio ready`
  # invoked from the wrong pane even if the per-tab API call below were to
  # regress to a focused-tab call.
  if [[ -n "${ZELLIJ_TAB:-}" && "$ZELLIJ_TAB" != "$bare" ]]; then
    _log "_rename_tab: \$ZELLIJ_TAB=$ZELLIJ_TAB != role tab=$bare — skipping"
    return 0
  fi

  case "$new_state" in
    idle) prefix="⏸️ " ;;
    busy) prefix="▶️ " ;;
    *)    return 0 ;;
  esac
  new_name="${prefix}${bare}"

  # Resolve the role's tab via its currently-recorded visible name and rename
  # by stable id. This makes the rename insensitive to which tab the user has
  # focused at the moment the hook fires — pre-#102 we used
  # `zellij action rename-tab`, which targets whatever tab is focused and so
  # clobbered the PM tab when a worker auto-unregistered while the user was
  # parked there.
  local tab_id
  tab_id=$(_zellij_tab_id_by_name "$current")
  [[ -n "$tab_id" ]] || { _log "_rename_tab: tab '$current' not found — skipping"; return 0; }

  zellij action rename-tab-by-id "$tab_id" "$new_name" >/dev/null 2>&1 || return 0

  # Persist the new visible name back to the session file so future lookups
  # (`_zellij_tab_id_by_name` here, and again in `cmd_send`) find the tab by
  # its current name.
  awk -v t="$new_name" '
    /^TAB=/ { print "TAB=" t; seen=1; next }
    { print }
    END { if (!seen) print "TAB=" t }
  ' "$f" | _atomic_write "$f"
}

# ----- subcommands ----------------------------------------------------------

cmd_register() {
  local role="" tab="" repo="" agent="" loadout=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --role)    role="$2";    shift 2 ;;
      --tab)     tab="$2";     shift 2 ;;
      --repo)    repo="$2";    shift 2 ;;
      --agent)   agent="$2";   shift 2 ;;
      --loadout) loadout="$2"; shift 2 ;;
      *) echo "register: unknown flag $1" >&2; exit 2 ;;
    esac
  done
  [[ -n "$role"  ]] || { echo "register: --role required"  >&2; exit 2; }
  [[ -n "$agent" ]] || { echo "register: --agent required" >&2; exit 2; }
  _validate_role "$role" || exit 2

  local f
  f=$(_session_file "$role")
  printf 'ROLE=%s\nTAB=%s\nREPO=%s\nSTATE=idle\nLAST_HEARTBEAT=%s\nAGENT=%s\nLOADOUT=%s\n' \
    "$role" "$tab" "$repo" "$(_now)" "$agent" "$loadout" \
    | _atomic_write "$f"

  mkdir -p "$(_inbox_dir "$role")" "$(_processed_dir "$role")"
  _log "register role=$role tab=$tab agent=$agent loadout=$loadout"

  # First paint of the idle prefix without waiting for a Stop hook cycle (#95).
  # _rename_tab reads $TASK_FORCE_ROLE, which the SessionStart hook sets to the
  # same value as --role here (`radio register --role $TASK_FORCE_ROLE …`).
  _rename_tab idle
}

cmd_unregister() {
  _silent_exit_if_no_role
  _require_role
  local f
  f=$(_session_file "$TASK_FORCE_ROLE")
  rm -f "$f"
  _log "unregister role=$TASK_FORCE_ROLE"
}

cmd_ready() { _silent_exit_if_no_role; _update_state idle; }
cmd_busy()  { _silent_exit_if_no_role; _update_state busy; }

cmd_send() {
  local to="" intent="" pr="" issue="" repo="" body=""
  local body_set=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --to)     to="$2";     shift 2 ;;
      --intent) intent="$2"; shift 2 ;;
      --pr)     pr="$2";     shift 2 ;;
      --issue)  issue="$2";  shift 2 ;;
      --repo)   repo="$2";   shift 2 ;;
      --body)   body="$2"; body_set=1; shift 2 ;;
      *) echo "send: unknown flag $1" >&2; exit 2 ;;
    esac
  done
  [[ -n "$to"     ]] || { echo "send: --to required"     >&2; exit 2; }
  [[ -n "$intent" ]] || { echo "send: --intent required" >&2; exit 2; }
  _validate_role "$to" || exit 2

  local from="${TASK_FORCE_ROLE:-unknown}"
  local id
  id="$(_compact_now)-from-${from}-$(_rand_id)"
  local inbox
  inbox=$(_inbox_dir "$to")
  mkdir -p "$inbox"
  local msg="$inbox/${id}.md"

  if [[ "$body_set" -eq 0 ]] && [[ ! -t 0 ]]; then
    body=$(cat)
  fi

  {
    printf -- '---\n'
    printf 'id: %s\n' "$id"
    printf 'from: %s\n' "$from"
    printf 'to: %s\n' "$to"
    printf 'intent: %s\n' "$intent"
    [[ -n "$pr"    ]] && printf 'pr: %s\n'    "$pr"
    [[ -n "$issue" ]] && printf 'issue: %s\n' "$issue"
    [[ -n "$repo"  ]] && printf 'repo: %s\n'  "$repo"
    printf 'created_at: %s\n' "$(_now)"
    printf -- '---\n'
    printf '%s\n' "$body"
  } | _atomic_write "$msg"

  _log "send id=$id from=$from to=$to intent=$intent"

  # Wake the recipient — only if zellij is running, the recipient is registered,
  # idle, and has a tab name. Any other case is a silent no-op (logged).
  if [[ -z "${ZELLIJ:-}" ]]; then
    _log "send: \$ZELLIJ unset — skipping zellij wake (id=$id)"
    return 0
  fi
  local rs
  rs=$(_session_file "$to")
  if [[ ! -f "$rs" ]]; then
    _log "send: no session for $to — message queued (id=$id)"
    return 0
  fi
  local rstate rtab
  rstate=$(_session_field "$rs" STATE || true)
  rtab=$(_session_field "$rs" TAB || true)
  if [[ "$rstate" != "idle" ]]; then
    _log "send: $to is busy (state=$rstate) — queued (id=$id)"
    return 0
  fi
  if [[ -z "$rtab" ]]; then
    _log "send: $to has no TAB — queued (id=$id)"
    return 0
  fi
  # Wake-up via per-pane targeting (#102): resolve the recipient's tab_id and a
  # writable pane id on it, then `write-chars --pane-id` straight into that
  # pane. Pre-#102 we did `go-to-tab-name` + `write-chars`, which yanked the
  # user's focus globally and — because `write-chars` runs in the sender's
  # pane context — could deliver "radio check" to the wrong tab when the
  # sender wasn't already on the recipient's tab.
  local rtab_id rpane_id
  rtab_id=$(_zellij_tab_id_by_name "$rtab")
  if [[ -z "$rtab_id" ]]; then
    _log "send: tab '$rtab' not found in zellij — queued (id=$id)"
    return 0
  fi
  rpane_id=$(_zellij_pane_in_tab "$rtab_id")
  if [[ -z "$rpane_id" ]]; then
    _log "send: no writable pane on tab '$rtab' (tab_id=$rtab_id) — queued (id=$id)"
    return 0
  fi
  # Only ever write the literal string "radio check\n" — never the message body
  # or any caller-supplied data. `zellij write-chars` injects directly into the
  # recipient's TUI input buffer; writing anything else risks corrupting the
  # agent's unsaved prompt or smuggling content into a TUI command. The
  # recipient reads the actual message via `radio check` / `radio read`.
  zellij action write-chars --pane-id "$rpane_id" "radio check"$'\n' >/dev/null 2>&1 || {
    _log "send: write-chars failed for $to (pane=$rpane_id) — queued (id=$id)"; return 0; }
  _log "send: woke $to via tab=$rtab pane=$rpane_id (id=$id)"
}

cmd_check() {
  _silent_exit_if_no_role
  _require_role
  local inbox
  inbox=$(_inbox_dir "$TASK_FORCE_ROLE")
  [[ -d "$inbox" ]] || { mkdir -p "$inbox"; return 0; }
  shopt -s nullglob
  local any=0
  for f in "$inbox"/*.md; do
    any=1
    local id from intent oneline
    id=$(basename "$f" .md)
    from=$(awk -F': ' '/^from:/{print $2; exit}' "$f")
    intent=$(awk -F': ' '/^intent:/{print $2; exit}' "$f")
    # First non-frontmatter, non-blank line:
    oneline=$(awk '/^---$/ { f++; next } f >= 2 && NF { print; exit }' "$f")
    printf '%s\tfrom=%s\tintent=%s\t%s\n' "$id" "$from" "$intent" "$oneline"
  done
  shopt -u nullglob
  [[ "$any" -eq 1 ]] || echo "(no unread messages)"
}

cmd_read() {
  _require_role
  local id="${1:-}"
  [[ -n "$id" ]] || { echo "read: <id> required" >&2; exit 2; }
  local f
  f="$(_inbox_dir "$TASK_FORCE_ROLE")/${id}.md"
  if [[ ! -f "$f" ]]; then
    f="$(_processed_dir "$TASK_FORCE_ROLE")/${id}.md"
  fi
  [[ -f "$f" ]] || { echo "read: message $id not found" >&2; exit 1; }
  cat "$f"
}

cmd_ack() {
  _require_role
  local id="${1:-}"
  [[ -n "$id" ]] || { echo "ack: <id> required" >&2; exit 2; }
  local inbox processed
  inbox=$(_inbox_dir "$TASK_FORCE_ROLE")
  processed=$(_processed_dir "$TASK_FORCE_ROLE")
  local src="$inbox/${id}.md"
  [[ -f "$src" ]] || { echo "ack: message $id not in inbox" >&2; exit 1; }
  mkdir -p "$processed"
  mv -f "$src" "$processed/"
  _log "ack id=$id role=$TASK_FORCE_ROLE"
}

cmd_orphans() {
  [[ -d "$SESSIONS_DIR" ]] || return 0
  local now_epoch
  now_epoch=$(date -u +%s)
  shopt -s nullglob
  for f in "$SESSIONS_DIR"/*.info; do
    local hb hb_epoch role age
    hb=$(_session_field "$f" LAST_HEARTBEAT || true)
    role=$(_session_field "$f" ROLE || basename "$f" .info)
    if [[ -z "$hb" ]]; then
      printf '%s\t(no LAST_HEARTBEAT)\n' "$role"
      continue
    fi
    # POSIX-portable parse of UTC ISO-8601 (YYYY-MM-DDTHH:MM:SSZ) -> epoch.
    # GNU date supports -d; BSD date wants -j -f. Try GNU first, then BSD.
    hb_epoch=$(date -u -d "$hb" +%s 2>/dev/null \
               || date -u -j -f "%Y-%m-%dT%H:%M:%SZ" "$hb" +%s 2>/dev/null \
               || echo 0)
    age=$(( now_epoch - hb_epoch ))
    if (( age > 3600 )); then
      printf '%s\tage=%ss\thb=%s\n' "$role" "$age" "$hb"
    fi
  done
  shopt -u nullglob
}

# ----- dispatch -------------------------------------------------------------

mkdir -p "$SESSIONS_DIR" "$MAILBOX_DIR"
sub="${1:-}"
[[ -n "$sub" ]] || usage
shift || true
case "$sub" in
  send)        cmd_send "$@" ;;
  check)       cmd_check ;;
  read)        cmd_read "$@" ;;
  ack)         cmd_ack "$@" ;;
  # Dispatcher gate (#93): the SessionStart hook fires `register --role $TASK_FORCE_ROLE`,
  # which substitutes to `--role ""` when the env var is unset (plain `claude`
  # session in a task-force-equipped repo). Silently no-op in that case rather
  # than erroring out. A user invoking `radio register` directly will normally
  # have $TASK_FORCE_ROLE set (from task-work / task-pm), so they still hit the
  # loud `register: --role required` / `--agent required` errors in cmd_register
  # if they forget a flag — typo protection preserved.
  register)    [[ -z "${TASK_FORCE_ROLE:-}" ]] && exit 0; cmd_register "$@" ;;
  ready)       cmd_ready ;;
  busy)        cmd_busy ;;
  unregister)  cmd_unregister ;;
  orphans)     cmd_orphans ;;
  -h|--help)   usage 0 ;;
  *) echo "radio: unknown subcommand '$sub'" >&2; usage 1 ;;
esac
# endregion:body
