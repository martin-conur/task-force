#!/usr/bin/env bash
# Stub for zellij — records every invocation and emits canned JSON for the
# read-only `list-tabs --json` / `list-panes --json --tab` lookups that
# `_zellij_tab_id_by_name` / `_zellij_pane_in_tab` make. Tests opt into a
# specific fixture via $STUB_ZELLIJ_TABS_JSON / $STUB_ZELLIJ_PANES_JSON;
# unset env vars produce empty stdout, which the radio helpers correctly
# treat as "lookup failed — skip" (mirrors the real behaviour when zellij
# isn't running). Mutating actions stay no-ops; we just record the call.
echo "zellij $*" >> "${STUB_CALLS_DIR}/zellij.calls"
case "$*" in
  "action list-tabs --json")
    [[ -n "${STUB_ZELLIJ_TABS_JSON:-}" ]] && printf '%s' "$STUB_ZELLIJ_TABS_JSON"
    ;;
  "action list-panes --json --tab")
    [[ -n "${STUB_ZELLIJ_PANES_JSON:-}" ]] && printf '%s' "$STUB_ZELLIJ_PANES_JSON"
    ;;
  "list-sessions --no-formatting")
    # The #167 concurrency guard (_zellij_session_alive) reads this to decide
    # whether a recipient's recorded session is still live in another server.
    # Tests opt in via $STUB_ZELLIJ_SESSIONS (one "<name> [Created …] (…)" line
    # per session); unset → empty → "no live sessions" (the common single-server
    # case, where recorded==current so the guard is never consulted anyway).
    [[ -n "${STUB_ZELLIJ_SESSIONS:-}" ]] && printf '%s\n' "$STUB_ZELLIJ_SESSIONS"
    ;;
  "action go-to-tab "*)
    # Lets tests pin the contract that aw_launch_tab's `|| true` swallows
    # a non-zero go-to-tab without aborting the worker spawn.
    [[ -n "${STUB_ZELLIJ_GOTO_TAB_FAIL:-}" ]] && exit 1
    ;;
  "action new-tab "*)
    # Lets tests pin that task-reviewer's ERR trap unwinds the worktree +
    # branch + info file when aw_launch_tab fails partway through (#139).
    [[ -n "${STUB_ZELLIJ_NEW_TAB_FAIL:-}" ]] && exit 1
    ;;
  "action write-chars "*)
    # Lets tests pin cmd_send's write-chars-failed outcome line (#166): the
    # pane resolves but the actual write returns non-zero.
    [[ -n "${STUB_ZELLIJ_WRITE_CHARS_FAIL:-}" ]] && exit 1
    ;;
esac
exit 0
